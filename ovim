def draw_scrollable(stdscr, lines, title, extra_hint=""):
    scroll = 0
    while True:
        stdscr.erase()
        height, width = stdscr.getmaxyx()
        stdscr.addstr(0, 0, title.center(width)[:width-1],
                      curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD)
        visible = lines[scroll:scroll + height - 2]
        for i, line in enumerate(visible):
            if line.startswith('+') and not line.startswith('+++'):
                color = curses.color_pair(COLOR_DIFF_ADD)
            elif line.startswith('-') and not line.startswith('---'):
                color = curses.color_pair(COLOR_DIFF_DEL)
            elif line.startswith('@@'):
                color = curses.color_pair(COLOR_DIFF_HDR)
            elif any(line.startswith(k) for k in ('commit', 'Author', 'Date', 'On branch', 'Your branch')):
                color = curses.color_pair(COLOR_GIT_HASH)
            elif line.startswith('Changes') or line.startswith('Untracked') or line.startswith('nothing'):
                color = curses.color_pair(COLOR_GIT_REF)
            else:
                color = curses.color_pair(COLOR_NORMAL)
            try:
                stdscr.addstr(i + 1, 0, line[:width-1], color)
            except:
                pass
        hint = f" [↑↓/PgUp/PgDn] scroll  {extra_hint}[q] close  [{scroll+1}/{len(lines)}] "
        stdscr.addstr(height-1, 0, hint.ljust(width-1)[:width-1], curses.color_pair(COLOR_STATUSBAR))
        stdscr.refresh()
        key = stdscr.getch()
        if key in (ord('q'), ord('Q'), 27):
            return False
        elif key in (curses.KEY_ENTER, 10, 13):
            return True
        elif key == curses.KEY_UP and scroll > 0:
            scroll -= 1
        elif key == curses.KEY_DOWN and scroll < max(0, len(lines) - (height - 2)):
            scroll += 1
        elif key == curses.KEY_PPAGE:
            scroll = max(0, scroll - (height - 2))
        elif key == curses.KEY_NPAGE:
            scroll = min(max(0, len(lines) - (height - 2)), scroll + (height - 2))

def git_result_popup(stdscr, title, out, err):
    lines = []
    if out:
        lines += out.splitlines()
    if err:
        lines += err.splitlines()
    if not lines:
        lines = ["done!"]
    draw_scrollable(stdscr, lines, title)

