HIGHLIGHTS = {
    "python": [
        (COLOR_COMMENT,  r'#.*$'),
        (COLOR_STRING,   r'\"\"\"[\s\S]*?\"\"\"|\'\'\'[\s\S]*?\'\'\'|\".*?\"|\'.*?\''),
