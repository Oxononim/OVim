def new_buffer(filename=None):
    lines = [""]
    if filename and os.path.exists(filename):
        with open(filename, 'r') as f:
            content = f.read().splitlines()
        if content:
            lines = content
    return {
        "lines":       lines,
        "filename":    filename,
        "row":         0,
        "col":         0,
        "scroll_top":  0,
        "scroll_left": 0,
        "modified":    False,
        "undo_stack":  [],
        "redo_stack":  [],
    }

def apply_theme(stdscr=None):
    for key, (pair, fg, bg) in theme.items():
        curses.init_pair(pair, fg, bg)
    curses.init_pair(COLOR_SEARCH,     curses.COLOR_BLACK,   curses.COLOR_YELLOW)
    curses.init_pair(COLOR_DIFF_ADD,   curses.COLOR_GREEN,   -1)
    curses.init_pair(COLOR_DIFF_DEL,   curses.COLOR_RED,     -1)
    curses.init_pair(COLOR_DIFF_HDR,   curses.COLOR_CYAN,    -1)
    curses.init_pair(COLOR_GIT_HASH,   curses.COLOR_YELLOW,  -1)
    curses.init_pair(COLOR_GIT_REF,    curses.COLOR_GREEN,   -1)
    curses.init_pair(COLOR_GIT_GRAPH,  curses.COLOR_CYAN,    -1)
    curses.init_pair(COLOR_MARK,       curses.COLOR_WHITE,   curses.COLOR_RED)
    curses.init_pair(COLOR_GUTTER_ADD, curses.COLOR_GREEN,   -1)
    curses.init_pair(COLOR_GUTTER_MOD, curses.COLOR_YELLOW,  -1)
    curses.init_pair(COLOR_GUTTER_DEL, curses.COLOR_RED,     -1)
    if stdscr:
        stdscr.bkgd(' ', curses.color_pair(COLOR_BACKGROUND))

def save_theme_to_file(name, tab_size, word_wrap):
    os.makedirs(THEME_DIR, exist_ok=True)
    data = {"tab_size": tab_size[0], "word_wrap": word_wrap[0]}
    for key, (pair, fg, bg) in theme.items():
        data[key] = {"pair": pair, "fg": COLOR_ID_TO_NAME.get(fg, "Default"), "bg": COLOR_ID_TO_NAME.get(bg, "Default")}
    path = os.path.join(THEME_DIR, f"{name}.json")
    with open(path, 'w') as f:
        json.dump(data, f, indent=2)
    return path

def load_theme_from_file(name, tab_size, word_wrap):
    path = os.path.join(THEME_DIR, f"{name}.json")
    if not os.path.exists(path):
        return False
    with open(path, 'r') as f:
        data = json.load(f)
    name_to_id = {k: v for k, v in COLOR_NAMES}
    if "tab_size" in data:
        tab_size[0] = data["tab_size"]
    if "word_wrap" in data:
        word_wrap[0] = data["word_wrap"]
    for key, val in data.items():
        if key in theme and isinstance(val, dict):
            theme[key] = (val["pair"], name_to_id.get(val["fg"], -1), name_to_id.get(val["bg"], -1))
    return True

def list_saved_themes():
    if not os.path.exists(THEME_DIR):
        return []
    return [f[:-5] for f in os.listdir(THEME_DIR) if f.endswith(".json")]

def highlight_line(line, lang, search_pattern=None):
    spans = []
    if lang and lang in HIGHLIGHTS:
        for color, pattern in HIGHLIGHTS[lang]:
            for m in re.finditer(pattern, line):
                spans.append((m.start(), m.end(), color))
    if search_pattern:
        try:
            for m in re.finditer(search_pattern, line):
                spans.append((m.start(), m.end(), COLOR_SEARCH))
        except re.error:
            pass
    if not spans:
        return [(line, COLOR_NORMAL)]
    spans.sort(key=lambda s: s[0])
    merged = []
    for span in spans:
        if merged and span[0] < merged[-1][1]:
            if span[2] == COLOR_SEARCH:
                last = merged[-1]
                if last[0] < span[0]:
                    merged[-1] = (last[0], span[0], last[2])
                else:
                    merged.pop()
                merged.append(span)
            continue
        merged.append(span)
    chunks = []
    pos = 0
    for start, end, color in merged:
        if pos < start:
            chunks.append((line[pos:start], COLOR_NORMAL))
        chunks.append((line[start:end], color))
        pos = end
    if pos < len(line):
        chunks.append((line[pos:], COLOR_NORMAL))
    return chunks

def get_search_matches(lines, pattern):
    matches = []
    if not pattern:
        return matches
    try:
        for i, line in enumerate(lines):
            for m in re.finditer(pattern, line):
                matches.append((i, m.start()))
    except re.error:
        pass
    return matches

def draw_menu(stdscr, title, options):
    height, width = stdscr.getmaxyx()
    menu_h = min(len(options) + 4, height - 2)
    menu_w = min(max(len(title), max(len(o) for o in options)) + 6, width - 2)
    y = (height - menu_h) // 2
    x = (width  - menu_w) // 2
    selected = 0
    visible_count = menu_h - 4
    scroll = 0
    while True:
        stdscr.attron(curses.color_pair(COLOR_STATUSBAR))
        for i in range(menu_h):
            try:
                stdscr.addstr(y + i, x, " " * menu_w)
            except:
                pass
        stdscr.attroff(curses.color_pair(COLOR_STATUSBAR))
        try:
            stdscr.addstr(y + 1, x + (menu_w - len(title)) // 2, title[:menu_w-2],
                          curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD)
        except:
            pass
        for i in range(visible_count):
            oi = scroll + i
            if oi >= len(options):
                break
            attr = curses.color_pair(COLOR_STATUSBAR) | curses.A_REVERSE if oi == selected \
                   else curses.color_pair(COLOR_STATUSBAR)
            try:
                stdscr.addstr(y + 2 + i, x + 2, options[oi][:menu_w-4].ljust(menu_w - 4), attr)
            except:
                pass
        stdscr.refresh()
        key = stdscr.getch()
        if key == curses.KEY_UP and selected > 0:
            selected -= 1
            if selected < scroll:
                scroll = selected
        elif key == curses.KEY_DOWN and selected < len(options) - 1:
            selected += 1
            if selected >= scroll + visible_count:
                scroll = selected - visible_count + 1
        elif key in (curses.KEY_ENTER, 10, 13):
            return selected
        elif key == 27:
            return None

def draw_color_picker(stdscr, title):
    idx = draw_menu(stdscr, title, [name for name, _ in COLOR_NAMES])
    if idx is None:
        return None
    return COLOR_NAMES[idx][1]

def prompt_input(stdscr, prompt):
    height, width = stdscr.getmaxyx()
    stdscr.addstr(height-1, 0, prompt.ljust(width-1), curses.color_pair(COLOR_STATUSBAR))
    curses.echo()
    curses.curs_set(1)
    stdscr.move(height-1, len(prompt))
    try:
        val = stdscr.getstr(height-1, len(prompt), 80).decode()
    except:
        val = ""
    curses.noecho()
    return val

def theme_builder(stdscr, tab_size, word_wrap):
    selected = 0
    message = ""
    while True:
        stdscr.clear()
        height, width = stdscr.getmaxyx()
        preview_w = width // 2
        side_w = width - preview_w - 1
        stdscr.addstr(0, 0, " THEME BUILDER ".center(width), curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD)
        stdscr.addstr(1, 0, " PREVIEW".ljust(preview_w), curses.color_pair(COLOR_STATUSBAR))
        for i, line in enumerate(PREVIEW_CODE):
            x = 1
            for text, color in highlight_line(line, "python"):
                if x < preview_w - 1:
                    stdscr.addstr(2 + i, x, text[:preview_w - x - 1], curses.color_pair(color))
                    x += len(text)
        stdscr.addstr(height-1, 0, " -- NORMAL -- file.py", curses.color_pair(COLOR_STATUSBAR))
        stdscr.addstr(height-1, 22, " main ", curses.color_pair(COLOR_GITBRANCH))
        stdscr.addstr(height-1, 28, " python  42w ", curses.color_pair(COLOR_STATUSBAR))
        for i in range(1, height - 2):
            stdscr.addstr(i, preview_w, "│", curses.color_pair(COLOR_NORMAL))
        stdscr.addstr(1, preview_w + 1, " ELEMENTS".ljust(side_w), curses.color_pair(COLOR_STATUSBAR))
        for i, (label, key) in enumerate(ELEMENTS):
            if key == "__wrap__":
                entry = f" {label}: {'ON' if word_wrap[0] else 'OFF'}"
                color = COLOR_STATUSBAR
            else:
                pair, fg, bg = theme[key]
                entry = f" {label}: {COLOR_ID_TO_NAME.get(fg,'Default')}/{COLOR_ID_TO_NAME.get(bg,'Default')}"
                color = pair
            attr = curses.color_pair(COLOR_STATUSBAR) | curses.A_REVERSE if i == selected else curses.color_pair(color)
            stdscr.addstr(2 + i, preview_w + 1, entry.ljust(side_w), attr)
        bottom = " [Enter] Edit/Toggle  [S] Save  [L] Load  [D] Delete  [T] Tab size  [Q] Done"
        if message:
            bottom = f" {message}"
        stdscr.addstr(height-2, 0, bottom.ljust(width-1), curses.color_pair(COLOR_STATUSBAR))
        stdscr.refresh()
        key = stdscr.getch()
        message = ""
        if key == curses.KEY_UP and selected > 0:
            selected -= 1
        elif key == curses.KEY_DOWN and selected < len(ELEMENTS) - 1:
            selected += 1
        elif key in (curses.KEY_ENTER, 10, 13):
            _, elem_key = ELEMENTS[selected]
            if elem_key == "__wrap__":
                word_wrap[0] = not word_wrap[0]
                message = f"word wrap {'ON' if word_wrap[0] else 'OFF'}"
                continue
            new_fg = draw_color_picker(stdscr, f" {ELEMENTS[selected][0]} FG ")
            if new_fg is None:
                continue
            new_bg = draw_color_picker(stdscr, f" {ELEMENTS[selected][0]} BG ")
            if new_bg is None:
                continue
            theme[elem_key] = (theme[elem_key][0], new_fg, new_bg)
            apply_theme(stdscr)
        elif key in (ord('s'), ord('S')):
            name = prompt_input(stdscr, " Save theme as: ")
            if name.strip():
                message = f"saved to {save_theme_to_file(name.strip(), tab_size, word_wrap)}"
        elif key in (ord('l'), ord('L')):
            saved = list_saved_themes()
            if not saved:
                message = "no saved themes found!"
            else:
                idx = draw_menu(stdscr, " LOAD THEME ", saved + ["Cancel"])
                if idx is not None and idx < len(saved):
                    if load_theme_from_file(saved[idx], tab_size, word_wrap):
                        apply_theme(stdscr)
                        message = f"loaded {saved[idx]}"
        elif key in (ord('d'), ord('D')):
            saved = list_saved_themes()
            if not saved:
                message = "no saved themes found!"
            else:
                idx = draw_menu(stdscr, " DELETE THEME ", saved + ["Cancel"])
                if idx is not None and idx < len(saved):
                    if draw_menu(stdscr, " ARE YOU SURE? ", ["Yes, delete it", "Cancel"]) == 0:
                        os.remove(os.path.join(THEME_DIR, f"{saved[idx]}.json"))
                        message = f"deleted {saved[idx]}"
        elif key in (ord('t'), ord('T')):
            val = prompt_input(stdscr, " Tab size: ")
            try:
                tab_size[0] = max(1, int(val.strip()))
                message = f"tab size set to {tab_size[0]}"
            except ValueError:
                message = "invalid tab size"
        elif key in (ord('q'), ord('Q'), 27):
            break

def open_theme_menu(stdscr, tab_size, word_wrap):
    choice = draw_menu(stdscr, " THEME ", ["Presets", "Customize", "Theme Builder", "Cancel"])
    if choice is None or choice == 3:
        return
    if choice == 0:
        preset_names = list(PRESETS.keys())
        idx = draw_menu(stdscr, " PRESETS ", preset_names + ["Cancel"])
        if idx is not None and idx < len(preset_names):
            for key, val in PRESETS[preset_names[idx]].items():
                theme[key] = val
            apply_theme(stdscr)
    elif choice == 1:
        labels = [e[0] for e in ELEMENTS] + ["Done"]
        while True:
            idx = draw_menu(stdscr, " CUSTOMIZE ", labels)
            if idx is None or idx == len(ELEMENTS):
                break
            _, key = ELEMENTS[idx]
            if key == "__wrap__":
                word_wrap[0] = not word_wrap[0]
                continue
            new_fg = draw_color_picker(stdscr, f" {ELEMENTS[idx][0]} FG ")
            if new_fg is None:
                continue
            new_bg = draw_color_picker(stdscr, f" {ELEMENTS[idx][0]} BG ")
            if new_bg is None:
                continue
            theme[key] = (theme[key][0], new_fg, new_bg)
            apply_theme(stdscr)
    elif choice == 2:
        theme_builder(stdscr, tab_size, word_wrap)

def detect_language(filename, lines):
    if filename:
        ext = os.path.splitext(filename)[1]
        if ext == ".py":
            return "python"
        elif ext == ".sh":
            return "bash"
    if lines and lines[0].startswith("#!"):
        shebang = lines[0].lower()
        if "python" in shebang:
            return "python"
        elif "bash" in shebang or "sh" in shebang:
            return "bash"
    return None

def get_auto_indent(line, lang):
    indent = len(line) - len(line.lstrip())
    current_indent = line[:indent]
    stripped = line.rstrip()
    if lang == "python" and stripped.endswith(":"):
        return current_indent + "    "
    elif lang == "bash" and stripped.endswith(("then", "do", "{", "()")):
        return current_indent + "    "
    return current_indent

def copy_to_clipboard(text):
    try:
        subprocess.run(['wl-copy'], input=text.encode(), check=True)
    except:
        pass

def paste_from_clipboard():
    try:
        return subprocess.run(['wl-paste', '--no-newline'], capture_output=True).stdout.decode()
    except:
        return ""

def save(lines, filename):
    if filename:
        with open(filename, 'w') as f:
            f.write('\n'.join(lines))
        return True
    return False

def num_offset(total_lines, show_numbers):
    if show_numbers:
        return len(str(total_lines)) + 1
    return 0

def clamp_scroll(row, scroll_top, height):
    if row < scroll_top:
        scroll_top = row
    elif row >= scroll_top + height - 1:
        scroll_top = row - height + 2
    return scroll_top

def push_undo(buf):
    buf["undo_stack"].append((list(buf["lines"]), buf["row"], buf["col"]))
    buf["redo_stack"].clear()

def draw_tabbar(stdscr, buffers, current, width):
    x = 0
    for i, buf in enumerate(buffers):
        name = os.path.basename(buf["filename"]) if buf["filename"] else "[No Name]"
        if buf["modified"]:
            name += " ●"
        label = f" {name} "
        if x + len(label) > width:
            break
        attr = curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD if i == current \
               else curses.color_pair(COLOR_NORMAL) | curses.A_REVERSE
        stdscr.addstr(0, x, label, attr)
        x += len(label)
        stdscr.addstr(0, x, "│", curses.color_pair(COLOR_NORMAL))
        x += 1

def draw_statusbar(stdscr, height, width, mode, buf, lang, col, offset, message, tab_size, branch, word_wrap, mark_line):
    lines = buf["lines"]
    row = buf["row"]
    now = datetime.datetime.now().strftime("%a %d %b %H:%M")
    words = sum(len(l.split()) for l in lines)
    filename = buf["filename"]
    if message:
        left = f" {message}"
    else:
        left = f" -- {mode.upper()} -- {filename or '[No Name]'}"
        if mark_line is not None:
            left += f"  [MARK:{mark_line+1}]"
    right = f"{lang or 'plain'}  {words}w  tab:{tab_size}  {'wrap  ' if word_wrap else ''}ln {row+1}/{len(lines)}  col {col-offset+1}  {now} "
    if branch:
        branch_label = f" {branch} "
        padding = max(0, width - 1 - len(left) - len(branch_label) - len(right))
        stdscr.addstr(height-1, 0, left[:width-1], curses.color_pair(COLOR_STATUSBAR))
        bx = len(left)
        if bx < width - 1:
            stdscr.addstr(height-1, bx, branch_label[:width-1-bx], curses.color_pair(COLOR_GITBRANCH))
        rx = bx + len(branch_label)
        if rx < width - 1:
            stdscr.addstr(height-1, rx, (" " * padding + right)[:width-1-rx], curses.color_pair(COLOR_STATUSBAR))
    else:
        padding = max(0, width - len(left) - len(right))
        stdscr.addstr(height-1, 0, (left + " " * padding + right)[:width-1], curses.color_pair(COLOR_STATUSBAR))

def wrap_line(line, width, offset):
    text_width = width - offset
    if text_width <= 0 or len(line) <= text_width:
        return [line]
    chunks = []
    while line:
        chunks.append(line[:text_width])
        line = line[text_width:]
    return chunks

def draw_lines(stdscr, lines, scroll_top, text_height, offset, width, lang,
               search_pattern, show_numbers, word_wrap, mark_line, gutter_markers, scroll_left=0):
    total = len(lines)
    num_w = len(str(total))
    screen_row = 1

    if word_wrap:
        for li in range(scroll_top, total):
            if screen_row >= text_height + 1:
                break
            chunks = wrap_line(lines[li], width, offset)
            for ci, chunk in enumerate(chunks):
                if screen_row >= text_height + 1:
                    break
                x = 0
                if show_numbers:
                    if ci == 0:
                        num = str(li + 1).rjust(num_w) + " "
                        if li == mark_line:
                            nc = COLOR_MARK
                        elif (li + 1) in gutter_markers:
                            m = gutter_markers[li + 1]
                            nc = COLOR_GUTTER_ADD if m == '+' else COLOR_GUTTER_MOD if m == '~' else COLOR_GUTTER_DEL
                        else:
                            nc = COLOR_LINENR
                        stdscr.addstr(screen_row, 0, num, curses.color_pair(nc))
                    else:
                        stdscr.addstr(screen_row, 0, " " * offset, curses.color_pair(COLOR_LINENR))
                    x = offset
                for text, color in highlight_line(chunk, lang, search_pattern or None):
                    if x < width:
                        stdscr.addstr(screen_row, x, text[:width - x], curses.color_pair(color))
                        x += len(text)
                screen_row += 1
        while screen_row <= text_height:
            stdscr.addstr(screen_row, 0, "~", curses.color_pair(COLOR_TILDE))
            screen_row += 1
    else:
        visible = lines[scroll_top:scroll_top + text_height]
        for i, line in enumerate(visible):
            li = scroll_top + i
            x = 0
            if show_numbers:
                num = str(li + 1).rjust(num_w) + " "
                if li == mark_line:
                    nc = COLOR_MARK
                elif (li + 1) in gutter_markers:
                    m = gutter_markers[li + 1]
                    nc = COLOR_GUTTER_ADD if m == '+' else COLOR_GUTTER_MOD if m == '~' else COLOR_GUTTER_DEL
                else:
                    nc = COLOR_LINENR
                stdscr.addstr(i + 1, 0, num, curses.color_pair(nc))
                x = offset
            display = line[scroll_left:] if scroll_left < len(line) else ""
            for text, color in highlight_line(display, lang, search_pattern or None):
                if x < width:
                    stdscr.addstr(i + 1, x, text[:width - x], curses.color_pair(color))
                    x += len(text)
        for i in range(len(visible), text_height):
            stdscr.addstr(i + 1, 0, "~", curses.color_pair(COLOR_TILDE))

def get_cursor_screen_row(lines, row, col, offset, width, scroll_top):
    screen_row = 1
    text_width = width - offset
    for li in range(scroll_top, row):
        screen_row += len(wrap_line(lines[li], width, offset))
    if text_width > 0:
        char_col = col - offset
        chunk_idx = max(0, char_col // text_width)
        screen_row += chunk_idx
        screen_col = offset + (char_col % text_width)
    else:
        screen_col = col
    return screen_row, screen_col

def main(stdscr):
    curses.use_default_colors()
    curses.start_color()
    apply_theme(stdscr)
    curses.mousemask(curses.ALL_MOUSE_EVENTS)

    tab_size       = [4]
    word_wrap      = [False]
    show_numbers   = True
    mode           = "normal"
    command        = ""
    message        = ""
    search_pattern = ""
    search_matches = []
    search_idx     = 0
    g_pending      = False
    z_pending      = False
    dd_pending     = False
    yy_pending     = False
    yank_buffer    = ""
    branch         = None
    branch_timer   = 0
    mark_line      = None
    gutter_markers = {}
    gutter_timer   = 0

    if len(sys.argv) > 1:
        buffers = [new_buffer(sys.argv[1])]
    else:
        buffers = [new_buffer()]
    current_buf = 0
    branch = get_git_branch(buffers[current_buf]["filename"])
    gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])

    while True:
        buf         = buffers[current_buf]
        lines       = buf["lines"]
        row         = buf["row"]
        col         = buf["col"]
        scroll_top  = buf["scroll_top"]
        scroll_left = buf.get("scroll_left", 0)

        branch_timer += 1
        if branch_timer >= 100:
            branch = get_git_branch(buf["filename"])
            branch_timer = 0

        gutter_timer += 1
        if gutter_timer >= 50:
            gutter_markers = get_gutter_markers(buf["filename"])
            gutter_timer = 0

        stdscr.clear()
        height, width = stdscr.getmaxyx()
        lang   = detect_language(buf["filename"], lines)
        offset = num_offset(len(lines), show_numbers)

        col = max(col, offset)
        buf["col"] = col

        draw_tabbar(stdscr, buffers, current_buf, width)
        text_height = height - 2

        draw_lines(stdscr, lines, scroll_top, text_height, offset, width, lang,
                   search_pattern, show_numbers, word_wrap[0], mark_line, gutter_markers, scroll_left)

        if word_wrap[0]:
            cursor_screen_row, cursor_screen_col = get_cursor_screen_row(lines, row, col, offset, width, scroll_top)
            cursor_screen_row = min(cursor_screen_row, text_height)
        else:
            cursor_screen_row = row - scroll_top + 1
            cursor_screen_col = col - scroll_left

        if mode == "command":
            stdscr.addstr(height-1, 0, f":{command}    ", curses.color_pair(COLOR_STATUSBAR))
        elif mode == "search":
            stdscr.addstr(height-1, 0, f"/{search_pattern}    ", curses.color_pair(COLOR_STATUSBAR))
        else:
            draw_statusbar(stdscr, height, width, mode, buf, lang, col, offset, message, tab_size[0], branch, word_wrap[0], mark_line)

        try:
            stdscr.move(cursor_screen_row, max(0, cursor_screen_col))
        except:
            pass
        stdscr.refresh()

        key = stdscr.getch()
        message = ""

        if mode == "search":
            if key == 27:
                mode = "normal"
                search_pattern = ""
                search_matches = []
            elif key in (curses.KEY_ENTER, 10, 13):
                search_matches = get_search_matches(lines, search_pattern)
                if search_matches:
                    search_idx = 0
                    row, col = search_matches[0]
                    col += offset
                    buf["row"] = row
                    buf["col"] = col
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                    message = f"/{search_pattern}  [{search_idx+1}/{len(search_matches)}]"
                else:
                    message = f"pattern not found: {search_pattern}"
                mode = "normal"
            elif key in (curses.KEY_BACKSPACE, 127, 8):
                search_pattern = search_pattern[:-1]
            elif 32 <= key <= 126:
                search_pattern += chr(key)
            continue

        if key == curses.KEY_MOUSE:
            try:
                _, mx, my, _, bstate = curses.getmouse()
                if bstate & curses.BUTTON1_CLICKED:
                    new_row = my - 1 + scroll_top
                    if 0 <= new_row < len(lines):
                        row = new_row
                        col = max(min(mx + scroll_left, len(lines[row]) + offset), offset)
                        buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                elif bstate & curses.BUTTON4_PRESSED:
                    row = max(0, row - 3)
                    col = max(min(col, len(lines[row]) + offset), offset)
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                elif bstate & curses.BUTTON5_PRESSED:
                    row = min(len(lines) - 1, row + 3)
                    col = max(min(col, len(lines[row]) + offset), offset)
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                elif bstate & (1 << 22):
                    if not word_wrap[0]:
                        buf["scroll_left"] = max(0, scroll_left - 3)
                elif bstate & (1 << 23):
                    if not word_wrap[0]:
                        max_left = max(0, max(len(l) for l in lines) - (width - offset))
                        buf["scroll_left"] = min(max_left, scroll_left + 3)
                buf["row"] = row
                buf["col"] = col
            except curses.error:
                pass

        elif key == curses.KEY_UP and row > 0:
            row -= 1
            col = max(min(col, len(lines[row]) + offset), offset)
            buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
            buf["row"] = row
            buf["col"] = col
        elif key == curses.KEY_DOWN and row < len(lines) - 1:
            row += 1
            col = max(min(col, len(lines[row]) + offset), offset)
            buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
            buf["row"] = row
            buf["col"] = col
        elif key == curses.KEY_LEFT and col > offset:
            col -= 1
            if not word_wrap[0] and col < scroll_left + offset:
                buf["scroll_left"] = max(0, scroll_left - 1)
            buf["col"] = col
        elif key == curses.KEY_RIGHT and col < len(lines[row]) + offset:
            col += 1
            if not word_wrap[0] and col - offset >= scroll_left + width - offset:
                buf["scroll_left"] = scroll_left + 1
            buf["col"] = col

        elif mode == "normal":
            if key == ord(' '):
                open_theme_menu(stdscr, tab_size, word_wrap)
            elif key == ord('/'):
                mode = "search"
                search_pattern = ""
            elif key == ord('n'):
                if search_matches:
                    search_idx = (search_idx + 1) % len(search_matches)
                    row, col = search_matches[search_idx]
                    col += offset
                    buf["row"] = row
                    buf["col"] = col
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                    message = f"/{search_pattern}  [{search_idx+1}/{len(search_matches)}]"
            elif key == ord('N'):
                if search_matches:
                    search_idx = (search_idx - 1) % len(search_matches)
                    row, col = search_matches[search_idx]
                    col += offset
                    buf["row"] = row
                    buf["col"] = col
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                    message = f"/{search_pattern}  [{search_idx+1}/{len(search_matches)}]"
            elif key == ord('u'):
                if buf["undo_stack"]:
                    buf["redo_stack"].append((list(lines), row, col))
                    sl, sr, sc = buf["undo_stack"].pop()
                    buf["lines"] = sl
                    buf["row"] = sr
                    buf["col"] = sc
                    buf["scroll_top"] = clamp_scroll(sr, scroll_top, text_height)
                    message = "undone"
                else:
                    message = "nothing to undo"
            elif key == 18:
                if buf["redo_stack"]:
                    buf["undo_stack"].append((list(lines), row, col))
                    sl, sr, sc = buf["redo_stack"].pop()
                    buf["lines"] = sl
                    buf["row"] = sr
                    buf["col"] = sc
                    buf["scroll_top"] = clamp_scroll(sr, scroll_top, text_height)
                    message = "redone"
                else:
                    message = "nothing to redo"
            elif key == ord('g'):
                if g_pending:
                    row = 0
                    col = offset
                    buf["row"] = row
                    buf["col"] = col
                    buf["scroll_top"] = 0
                    g_pending = False
                else:
                    g_pending = True
                    z_pending = False
            elif key == ord('G'):
                row = len(lines) - 1
                col = offset
                buf["row"] = row
                buf["col"] = col
                buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                g_pending = False
            elif key == ord('z'):
                z_pending = not z_pending
                g_pending = False
            elif key == ord('h') and z_pending:
                if not word_wrap[0]:
                    buf["scroll_left"] = max(0, scroll_left - 5)
                z_pending = False
            elif key == ord('l') and z_pending:
                if not word_wrap[0]:
                    max_left = max(0, max(len(l) for l in lines) - (width - offset))
                    buf["scroll_left"] = min(max_left, scroll_left + 5)
                z_pending = False
            elif key == ord('t') and not z_pending and not g_pending:
                current_buf = (current_buf + 1) % len(buffers)
                branch = get_git_branch(buffers[current_buf]["filename"])
                gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                branch_timer = 0
            elif key == ord('T') and not z_pending and not g_pending:
                current_buf = (current_buf - 1) % len(buffers)
                branch = get_git_branch(buffers[current_buf]["filename"])
                gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                branch_timer = 0
            elif key == ord('i'):
                mode = "insert"
                dd_pending = False
                yy_pending = False
                g_pending = False
                z_pending = False
            elif key == ord(':'):
                mode = "command"
                command = ""
                g_pending = False
                z_pending = False
            elif key == ord('h') and not z_pending:
                if col > offset:
                    col -= 1
                    buf["col"] = col
            elif key == ord('l') and not z_pending:
                if col < len(lines[row]) + offset:
                    col += 1
                    buf["col"] = col
            elif key == ord('j'):
                if row < len(lines) - 1:
                    row += 1
                    col = max(min(col, len(lines[row]) + offset), offset)
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                    buf["row"] = row
                    buf["col"] = col
            elif key == ord('k'):
                if row > 0:
                    row -= 1
                    col = max(min(col, len(lines[row]) + offset), offset)
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                    buf["row"] = row
                    buf["col"] = col
            elif key == ord('o'):
                push_undo(buf)
                lines.insert(row + 1, "")
                row += 1
                col = offset
                mode = "insert"
                buf["modified"] = True
                buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                buf["row"] = row
                buf["col"] = col
            elif key == ord('x'):
                if col - offset < len(lines[row]):
                    push_undo(buf)
                    lines[row] = lines[row][:col-offset] + lines[row][col-offset+1:]
                    buf["modified"] = True
            elif key == ord('p'):
                text = yank_buffer if yank_buffer else paste_from_clipboard()
                if text:
                    push_undo(buf)
                    paste_lines = text.split('\n')
                    for j, pl in enumerate(paste_lines):
                        lines.insert(row + 1 + j, pl)
                    row += len(paste_lines)
                    col = offset
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                    buf["modified"] = True
                    buf["row"] = row
                    buf["col"] = col
                    message = "pasted"
            elif key == ord('P'):
                text = yank_buffer if yank_buffer else paste_from_clipboard()
                if text:
                    push_undo(buf)
                    paste_lines = text.split('\n')
                    for j, pl in enumerate(paste_lines):
                        lines.insert(row + j, pl)
                    col = offset
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                    buf["modified"] = True
                    buf["col"] = col
                    message = "pasted above"
            elif key == ord('d'):
                if dd_pending:
                    push_undo(buf)
                    if len(lines) > 1:
                        lines.pop(row)
                        if row >= len(lines):
                            row -= 1
                    else:
                        buf["lines"] = [""]
                    col = offset
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                    buf["modified"] = True
                    buf["row"] = row
                    buf["col"] = col
                    dd_pending = False
                else:
                    dd_pending = True
                    yy_pending = False
            elif key == ord('y'):
                if yy_pending:
                    yank_buffer = lines[row]
                    copy_to_clipboard(yank_buffer)
                    message = "line yanked!"
                    yy_pending = False
                else:
                    yy_pending = True
                    dd_pending = False
            elif key == 27:
                dd_pending = False
                yy_pending = False
                g_pending = False
                z_pending = False
                mark_line = None
                search_pattern = ""
                search_matches = []

        elif mode == "insert":
            if key == 27:
                mode = "normal"
                dd_pending = False
                yy_pending = False
            elif key == 9:
                push_undo(buf)
                tab = " " * tab_size[0]
                lines[row] = lines[row][:col-offset] + tab + lines[row][col-offset:]
                col += tab_size[0]
                buf["modified"] = True
                buf["col"] = col
            elif key in (curses.KEY_BACKSPACE, 127, 8):
                push_undo(buf)
                if col > offset:
                    lines[row] = lines[row][:col-offset-1] + lines[row][col-offset:]
                    col -= 1
                    buf["modified"] = True
                    buf["col"] = col
                elif row > 0:
                    col = len(lines[row - 1]) + offset
                    lines[row - 1] = lines[row - 1] + lines[row]
                    lines.pop(row)
                    row -= 1
                    buf["modified"] = True
                    buf["row"] = row
                    buf["col"] = col
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
            elif key in (curses.KEY_ENTER, 10, 13):
                push_undo(buf)
                indent = get_auto_indent(lines[row], lang)
                new_line = lines[row][col-offset:]
                lines[row] = lines[row][:col-offset]
                lines.insert(row + 1, indent + new_line)
                row += 1
                col = offset + len(indent)
                buf["modified"] = True
                buf["row"] = row
                buf["col"] = col
                buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
            elif 32 <= key <= 126:
                push_undo(buf)
                ch = chr(key)
                if ch in PAIRS:
                    closing = PAIRS[ch]
                    lines[row] = lines[row][:col-offset] + ch + closing + lines[row][col-offset:]
                    col += 1
                else:
                    lines[row] = lines[row][:col-offset] + ch + lines[row][col-offset:]
                    col += 1
                buf["modified"] = True
                buf["col"] = col

        elif mode == "command":
            if key == 27:
                mode = "normal"
                command = ""
            elif key in (curses.KEY_ENTER, 10, 13):
                cwd = get_git_root(buf["filename"])

                if command == "w":
                    if save(lines, buf["filename"]):
                        buf["modified"] = False
                        branch = get_git_branch(buf["filename"])
                        gutter_markers = get_gutter_markers(buf["filename"])
                        message = f"saved to {buf['filename']}"
                    else:
                        message = "no filename!"

                elif command == "q":
                    if buf["modified"]:
                        message = "unsaved changes! use :q! to force or :wq to save"
                    elif len(buffers) > 1:
                        buffers.pop(current_buf)
                        current_buf = min(current_buf, len(buffers) - 1)
                        branch = get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                    else:
                        break

                elif command == "q!":
                    if len(buffers) > 1:
                        buffers.pop(current_buf)
                        current_buf = min(current_buf, len(buffers) - 1)
                        branch = get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                    else:
                        break

                elif command == "wq":
                    save(lines, buf["filename"])
                    buf["modified"] = False
                    if len(buffers) > 1:
                        buffers.pop(current_buf)
                        current_buf = min(current_buf, len(buffers) - 1)
                        branch = get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                    else:
                        break

                elif command.startswith("w "):
                    buf["filename"] = command[2:]
                    save(lines, buf["filename"])
                    buf["modified"] = False
                    branch = get_git_branch(buf["filename"])
                    gutter_markers = get_gutter_markers(buf["filename"])
                    message = f"saved to {buf['filename']}"

                elif command == "tabnew":
                    buffers.append(new_buffer())
                    current_buf = len(buffers) - 1
                    branch = get_git_branch(buffers[current_buf]["filename"])
                    gutter_markers = {}

                elif command.startswith("tabnew "):
                    buffers.append(new_buffer(command[7:]))
                    current_buf = len(buffers) - 1
                    branch = get_git_branch(buffers[current_buf]["filename"])
                    gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])

                elif command.startswith("goto "):
                    try:
                        n = int(command[5:]) - 1
                        row = max(0, min(n, len(lines) - 1))
                        col = offset
                        buf["row"] = row
                        buf["col"] = col
                        buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                    except ValueError:
                        message = "invalid line number"

                elif command.startswith("set tabsize "):
                    try:
                        tab_size[0] = max(1, int(command[12:]))
                        message = f"tab size set to {tab_size[0]}"
                    except ValueError:
                        message = "invalid tab size"

                elif command == "set wrap":
                    word_wrap[0] = True
                    message = "word wrap ON"

                elif command == "set nowrap":
                    word_wrap[0] = False
                    buf["scroll_left"] = 0
                    message = "word wrap OFF"

                # ── Git commands ──────────────────────────────────────────────

                elif command == "gl":
                    git_tree(stdscr, cwd)
                    apply_theme(stdscr)
                    branch = get_git_branch(buf["filename"])

                elif command == "gs":
                    if cwd:
                        out, err = git_run(['status'], cwd=cwd)
                        draw_scrollable(stdscr, (out or err).splitlines(), " GIT STATUS ")
                    else:
                        message = "not a git repo"

                elif command == "gd":
                    if buf["filename"] and cwd:
                        out, err = git_run(['diff', buf["filename"]], cwd=cwd)
                        if out:
                            draw_scrollable(stdscr, out.splitlines(), f" GIT DIFF — {os.path.basename(buf['filename'])} ")
                        else:
                            message = "no changes to show"
                    else:
                        message = "no file open"

                elif command == "ga":
                    if buf["filename"] and cwd:
                        out, err = git_run(['add', buf["filename"]], cwd=cwd)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        message = f"staged {os.path.basename(buf['filename'])}" if not err else err
                    else:
                        message = "no file open"

                elif command == "gaa":
                    if cwd:
                        out, err = git_run(['add', '-A'], cwd=cwd)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        message = "staged all files" if not err else err
                    else:
                        message = "not a git repo"

                elif command == "gun":
                    if buf["filename"] and cwd:
                        out, err = git_run(['restore', '--staged', buf["filename"]], cwd=cwd)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        message = f"unstaged {os.path.basename(buf['filename'])}" if not err else err
                    else:
                        message = "no file open"

                elif command == "gc":
                    if cwd:
                        commit_msg = prompt_input(stdscr, " Commit message: ")
                        if commit_msg.strip():
                            out, err = git_run(['commit', '-m', commit_msg.strip()], cwd=cwd)
                            git_result_popup(stdscr, " GIT COMMIT ", out, err)
                            branch = get_git_branch(buf["filename"])
                            gutter_markers = get_gutter_markers(buf["filename"])
                        else:
                            message = "commit cancelled"
                    else:
                        message = "not a git repo"

                elif command == "gca":
                    if cwd:
                        commit_msg = prompt_input(stdscr, " Commit message: ")
                        if commit_msg.strip():
                            git_run(['add', '-A'], cwd=cwd)
                            out, err = git_run(['commit', '-m', commit_msg.strip()], cwd=cwd)
                            git_result_popup(stdscr, " GIT COMMIT ALL ", out, err)
                            branch = get_git_branch(buf["filename"])
                            gutter_markers = get_gutter_markers(buf["filename"])
                        else:
                            message = "commit cancelled"
                    else:
                        message = "not a git repo"

                elif command == "gp":
                    if cwd:
                        stdscr.addstr(height-1, 0, " pushing...".ljust(width-1), curses.color_pair(COLOR_STATUSBAR))
                        stdscr.refresh()
                        out, err = git_run(['push'], cwd=cwd)
                        git_result_popup(stdscr, " GIT PUSH ", out, err)
                    else:
                        message = "not a git repo"

                elif command == "gpl":
                    if cwd:
                        stdscr.addstr(height-1, 0, " pulling...".ljust(width-1), curses.color_pair(COLOR_STATUSBAR))
                        stdscr.refresh()
                        out, err = git_run(['pull'], cwd=cwd)
                        git_result_popup(stdscr, " GIT PULL ", out, err)
                        # reload file if it changed
                        if buf["filename"] and os.path.exists(buf["filename"]):
                            with open(buf["filename"], 'r') as f:
                                content = f.read().splitlines()
                            if content:
                                buf["lines"] = content
                            buf["modified"] = False
                        gutter_markers = get_gutter_markers(buf["filename"])
                        branch = get_git_branch(buf["filename"])
                    else:
                        message = "not a git repo"

                elif command == "gf":
                    if cwd:
                        stdscr.addstr(height-1, 0, " fetching...".ljust(width-1), curses.color_pair(COLOR_STATUSBAR))
                        stdscr.refresh()
                        out, err = git_run(['fetch'], cwd=cwd)
                        git_result_popup(stdscr, " GIT FETCH ", out, err)
                    else:
                        message = "not a git repo"

                elif command == "gb":
                    if cwd:
                        new_branch = prompt_input(stdscr, " New branch name: ")
                        if new_branch.strip():
                            out, err = git_run(['checkout', '-b', new_branch.strip()], cwd=cwd)
                            git_result_popup(stdscr, " GIT BRANCH ", out, err)
                            branch = get_git_branch(buf["filename"])
                        else:
                            message = "cancelled"
                    else:
                        message = "not a git repo"

                elif command == "gbd":
                    if cwd:
                        branches = get_git_branches(cwd)
                        if branches:
                            labels = [("* " if cur else "  ") + n for n, cur in branches] + ["Cancel"]
                            idx = draw_menu(stdscr, " DELETE BRANCH ", labels)
                            if idx is not None and idx < len(branches):
                                bname = branches[idx][0]
                                confirm = draw_menu(stdscr, " ARE YOU SURE? ", [f"Delete {bname}", "Cancel"])
                                if confirm == 0:
                                    out, err = git_run(['branch', '-d', bname], cwd=cwd)
                                    git_result_popup(stdscr, " GIT BRANCH DELETE ", out, err)
                                    branch = get_git_branch(buf["filename"])
                        else:
                            message = "no branches found"
                    else:
                        message = "not a git repo"

                elif command == "gsw":
                    if cwd:
                        branches = get_git_branches(cwd)
                        if branches:
                            labels = [("* " if cur else "  ") + n for n, cur in branches] + ["Cancel"]
                            idx = draw_menu(stdscr, " SWITCH BRANCH ", labels)
                            if idx is not None and idx < len(branches):
                                bname = branches[idx][0]
                                out, err = git_run(['checkout', bname], cwd=cwd)
                                git_result_popup(stdscr, " GIT SWITCH ", out, err)
                                branch = get_git_branch(buf["filename"])
                                gutter_markers = get_gutter_markers(buf["filename"])
                                if buf["filename"] and os.path.exists(buf["filename"]):
                                    with open(buf["filename"], 'r') as f:
                                        content = f.read().splitlines()
                                    if content:
                                        buf["lines"] = content
                                    buf["modified"] = False
                        else:
                            message = "no branches found"
                    else:
                        message = "not a git repo"

                elif command == "gst":
                    if cwd:
                        out, err = git_run(['stash'], cwd=cwd)
                        git_result_popup(stdscr, " GIT STASH ", out, err)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        if buf["filename"] and os.path.exists(buf["filename"]):
                            with open(buf["filename"], 'r') as f:
                                content = f.read().splitlines()
                            if content:
                                buf["lines"] = content
                            buf["modified"] = False
                    else:
                        message = "not a git repo"

                elif command == "gstp":
                    if cwd:
                        out, err = git_run(['stash', 'pop'], cwd=cwd)
                        git_result_popup(stdscr, " GIT STASH POP ", out, err)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        if buf["filename"] and os.path.exists(buf["filename"]):
                            with open(buf["filename"], 'r') as f:
                                content = f.read().splitlines()
                            if content:
                                buf["lines"] = content
                            buf["modified"] = False
                    else:
                        message = "not a git repo"

                elif command == "md":
                    if mark_line is None:
                        mark_line = row
                        message = f"mark set at line {mark_line+1} -- move cursor and :md again to delete"
                    else:
                        start = min(mark_line, row)
                        end   = max(mark_line, row)
                        push_undo(buf)
                        del lines[start:end + 1]
                        if not lines:
                            buf["lines"] = [""]
                        row = max(0, start)
                        col = offset
                        buf["row"] = row
                        buf["col"] = col
                        buf["scroll_top"] = clamp_scroll(row, scroll_top, text_height)
                        buf["modified"] = True
                        message = f"deleted lines {start+1} to {end+1}"
                        mark_line = None

                else:
                    message = f"unknown command: {command}"

                mode = "normal"
                command = ""
            elif key in (curses.KEY_BACKSPACE, 127, 8):
                command = command[:-1]
            elif 32 <= key <= 126:
                command += chr(key)

curses.wrapper(main)