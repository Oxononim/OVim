def git_run(args, cwd):
    try:
        r=subprocess.run(['git']+args,capture_output=True,cwd=cwd)
        return r.stdout.decode(errors='replace').strip(), r.stderr.decode(errors='replace').strip()
    except: return "","git not found"

def get_git_root(filename):
    if not filename: return None
    try:
        r=subprocess.run(['git','rev-parse','--show-toplevel'],capture_output=True,
                         cwd=os.path.dirname(os.path.abspath(filename)))
        out=r.stdout.decode().strip(); return out if out else None
    except: return None

def get_git_branch(filename):
    if not filename: return None
    try:
        cwd=os.path.dirname(os.path.abspath(filename))
        r=subprocess.run(['git','branch','--show-current'],capture_output=True,cwd=cwd)
        b=r.stdout.decode().strip(); return b if b else None
    except: return None

def get_git_log(cwd):
    fmt='%x1f'.join(['%H','%D','%s','%an','%ar'])
    raw,_=git_run(['log','--graph','--all','--format=%x00'+fmt],cwd=cwd)
    entries=[]
    for line in raw.splitlines():
        if '\x00' in line:
            gp,rest=line.split('\x00',1); fields=rest.split('\x1f')
            if len(fields)>=5:
                h,refs,msg,author,date=fields[:5]
                entries.append({'graph':gp,'hash':h[:7],'fullhash':h,'refs':refs,'msg':msg,'author':author,'date':date})
            else: entries.append({'graph':gp,'hash':'','fullhash':'','refs':'','msg':'','author':'','date':''})
        else: entries.append({'graph':line,'hash':'','fullhash':'','refs':'','msg':'','author':'','date':''})
    return entries

def get_commit_diff(cwd,fh): out,_=git_run(['show','--stat',fh],cwd=cwd); return out
def get_commit_full_diff(cwd,fh): out,_=git_run(['show',fh],cwd=cwd); return out

def get_git_branches(cwd):
    raw,_=git_run(['branch','-a'],cwd=cwd); branches=[]
    for line in raw.splitlines():
        line=line.strip(); is_cur=line.startswith('*'); name=line.lstrip('* ').strip()
        if '->' not in name: branches.append((name,is_cur))
    return branches

def git_checkout(cwd,branch):
    try:
        r=subprocess.run(['git','checkout',branch],capture_output=True,cwd=cwd)
        return (r.stdout+r.stderr).decode().strip()
    except Exception as e: return str(e)

def get_gutter_markers(filename):
    markers={}
    if not filename or not os.path.exists(filename): return markers
    try:
        cwd=os.path.dirname(os.path.abspath(filename))
        r=subprocess.run(['git','diff','--unified=0',filename],capture_output=True,cwd=cwd)
        output=r.stdout.decode(errors='replace'); cl=0
        for line in output.splitlines():
            m=re.match(r'@@ -\d+(?:,\d+)? \+(\d+)(?:,(\d+))? @@',line)
            if m:
                cl=int(m.group(1)); count=int(m.group(2)) if m.group(2) is not None else 1
                if count==0: markers[max(1,cl)]='-'
                continue
            if line.startswith('+') and not line.startswith('+++'):
                markers[cl]='+'; cl+=1
            elif line.startswith('-') and not line.startswith('---'): markers[cl]='~'
            elif not line.startswith('\\'):
                if not line.startswith('-') and not line.startswith('+'): cl+=1
    except: pass
    return markers

