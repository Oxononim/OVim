# ─── Persistent config ────────────────────────────────────────────────────────

def load_config(tab_size, word_wrap, autosave_interval):
    if not os.path.exists(CONFIG_PATH):
        return
    try:
        with open(CONFIG_PATH, 'r') as f:
            data = json.load(f)
        name_to_id = {k: v for k, v in COLOR_NAMES}
        if "tab_size" in data:
            tab_size[0] = data["tab_size"]
        if "word_wrap" in data:
            word_wrap[0] = data["word_wrap"]
        if "autosave_interval" in data:
            autosave_interval[0] = data["autosave_interval"]
        if "theme" in data:
            for key, val in data["theme"].items():
                if key in theme and isinstance(val, dict):
                    theme[key] = (
                        val["pair"],
                        name_to_id.get(val["fg"], -1),
                        name_to_id.get(val["bg"], -1),
                    )
    except:
        pass

def save_config(tab_size, word_wrap, autosave_interval):
    os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
    data = {
        "tab_size":          tab_size[0],
        "word_wrap":         word_wrap[0],
        "autosave_interval": autosave_interval[0],
        "theme": {
            key: {
                "pair": pair,
                "fg":   COLOR_ID_TO_NAME.get(fg, "Default"),
                "bg":   COLOR_ID_TO_NAME.get(bg, "Default"),
            }
            for key, (pair, fg, bg) in theme.items()
        }
    }
    try:
        with open(CONFIG_PATH, 'w') as f:
            json.dump(data, f, indent=2)
    except:
        pass

# ─── Run panel ────────────────────────────────────────────────────────────────

class RunPanel:
    def __init__(self):
        self.output  = []
        self.running = False
        self.proc    = None
        self.thread  = None
        self.scroll  = 0
        self.lock    = threading.Lock()

    def start(self, filename, lang):
        self.stop()
        with self.lock:
            self.output = []
            self.scroll = 0
        self.running = True
        if lang == "python":
            cmd = ["python3", filename]
        elif lang == "bash":
            cmd = ["/bin/bash", filename]
        elif lang == "json":
            cmd = ["python3", "-m", "json.tool", filename]
        else:
            with self.lock:
                self.output.append(f"don't know how to run: {filename}")
            self.running = False
            return

        def run():
            try:
                self.proc = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                                             stderr=subprocess.STDOUT, text=True, bufsize=1)
                for line in self.proc.stdout:
                    with self.lock:
                        self.output.append(line.rstrip())
                self.proc.wait()
                with self.lock:
                    self.output.append("")
                    self.output.append(f"  [process exited with code {self.proc.returncode}]")
            except Exception as e:
                with self.lock:
                    self.output.append(f"error: {e}")
            finally:
                self.running = False

        self.thread = threading.Thread(target=run, daemon=True)
        self.thread.start()

    def stop(self):
        if self.proc:
            try:
                self.proc.terminate()
                self.proc = None
            except:
                pass
        self.running = False

    def get_output(self):
        with self.lock:
            return list(self.output)

    def draw(self, stdscr, top, height, width):
        status  = " RUNNING..." if self.running else " DONE "
        title   = f" OUTPUT {status}"
        hint    = " [:run close] close  [Ctrl+C] kill "
        padding = max(0, width - len(title) - len(hint))
        try:
            stdscr.addstr(top, 0, (title + " " * padding + hint)[:width-1],
                          curses.color_pair(COLOR_PANEL) | curses.A_BOLD)
        except:
            pass
        lines = self.get_output()
        if self.running:
            self.scroll = max(0, len(lines) - (height - 1))
        for i, line in enumerate(lines[self.scroll:self.scroll + height - 1]):
            if any(w in line.lower() for w in ('error', 'traceback', 'exception')):
                color = curses.color_pair(COLOR_DIFF_DEL)
            elif any(w in line.lower() for w in ('warning', 'warn')):
                color = curses.color_pair(COLOR_GUTTER_MOD)
            elif line.startswith("  [process exited"):
                color = curses.color_pair(COLOR_PANEL)
            else:
                color = curses.color_pair(COLOR_NORMAL)
            try:
                stdscr.addstr(top + 1 + i, 0, line[:width-1], color)
            except:
                pass

