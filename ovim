def draw_graph_line(stdscr, y, graph, hash_, refs, msg, author, date, selected, width):
    if selected:
        stdscr.attron(curses.A_REVERSE)
    x = 0
    for ch in graph:
        if x >= width - 1:
            break
        attr = curses.color_pair(COLOR_GIT_GRAPH) if ch in '|/\\*' else curses.color_pair(COLOR_NORMAL)
        if selected:
            attr |= curses.A_REVERSE
        try:
            stdscr.addch(y, x, ch, attr)
        except:
            pass
        x += 1
    if hash_:
        h_attr = curses.color_pair(COLOR_GIT_HASH) | (curses.A_REVERSE if selected else 0)
        try:
            stdscr.addstr(y, x, f" {hash_}"[:width-x-1], h_attr)
        except:
            pass
        x += len(f" {hash_}")
        if refs:
            for ref in [r.strip() for r in refs.split(',') if r.strip()]:
                if x >= width - 2:
                    break
                r_attr  = curses.color_pair(COLOR_GIT_REF) | (curses.A_REVERSE if selected else 0)
                ref_str = f" ({ref})"
                try:
                    stdscr.addstr(y, x, ref_str[:width-x-1], r_attr)
                except:
                    pass
                x += len(ref_str)
        if msg and x < width - 1:
            m_attr = curses.color_pair(COLOR_NORMAL) | (curses.A_REVERSE if selected else 0)
            try:
                stdscr.addstr(y, x, f" {msg}"[:width-x-1], m_attr)
            except:
                pass
    if selected:
        stdscr.attroff(curses.A_REVERSE)

def git_tree(stdscr, cwd):
    if not cwd:
        draw_menu(stdscr, " GIT TREE ", ["Not a git repo!", "OK"])
        return
    stdscr.erase()
    height, width = stdscr.getmaxyx()
    msg = " loading git log... "
    stdscr.addstr(height//2, (width-len(msg))//2, msg, curses.color_pair(COLOR_STATUSBAR))
    stdscr.refresh()
    entries = get_git_log(cwd)
    if not entries:
        draw_menu(stdscr, " GIT TREE ", ["No commits found!", "OK"])
        return
    commit_indices = [i for i, e in enumerate(entries) if e['hash']]
    if not commit_indices:
        draw_menu(stdscr, " GIT TREE ", ["No commits found!", "OK"])
        return
    selected_commit = 0
    scroll = 0
    while True:
        stdscr.erase()
        height, width = stdscr.getmaxyx()
        text_height   = height - 2
        stdscr.addstr(0, 0, " GIT TREE ".center(width)[:width-1],
                      curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD)
        for i in range(text_height):
            ei = scroll + i
            if ei >= len(entries):
                break
            e      = entries[ei]
            is_sel = ei in commit_indices and commit_indices.index(ei) == selected_commit
            draw_graph_line(stdscr, i+1, e['graph'], e['hash'], e['refs'],
                            e['msg'], e['author'], e['date'], is_sel, width)
        sel    = entries[commit_indices[selected_commit]]
        bottom = f" [{sel['hash']}] {sel['msg'][:35]}  [Enter] diff  [b] branches  [c] checkout  [q] quit "
        stdscr.addstr(height-1, 0, bottom[:width-1], curses.color_pair(COLOR_STATUSBAR))
        stdscr.refresh()
        key = stdscr.getch()
        if key in (ord('q'), ord('Q'), 27):
            break
        elif key == curses.KEY_UP and selected_commit > 0:
            selected_commit -= 1
            if commit_indices[selected_commit] < scroll:
                scroll = commit_indices[selected_commit]
        elif key == curses.KEY_DOWN and selected_commit < len(commit_indices) - 1:
            selected_commit += 1
            sel_line = commit_indices[selected_commit]
            if sel_line >= scroll + text_height:
                scroll = sel_line - text_height + 1
        elif key in (curses.KEY_ENTER, 10, 13):
            if sel['fullhash']:
                want_full = draw_scrollable(stdscr,
                    get_commit_diff(cwd, sel['fullhash']).splitlines(),
                    f" COMMIT {sel['hash']} — {sel['msg'][:50]} ", "[Enter] full diff  ")
                if want_full:
                    draw_scrollable(stdscr,
                        get_commit_full_diff(cwd, sel['fullhash']).splitlines(),
                        f" FULL DIFF {sel['hash']} ")
        elif key == ord('b'):
            branches = get_git_branches(cwd)
            if branches:
                labels = [("* " if cur else "  ") + n for n, cur in branches] + ["Cancel"]
                idx    = draw_menu(stdscr, " BRANCHES ", labels)
                if idx is not None and idx < len(branches):
                    bname = branches[idx][0]
                    for ci, e in enumerate(entries):
                        if e['hash'] and bname in e['refs'] and ci in commit_indices:
                            selected_commit = commit_indices.index(ci)
                            scroll = max(0, ci - text_height // 2)
                            break
        elif key == ord('c'):
            target = None
            if sel['refs']:
                for ref in sel['refs'].split(','):
                    ref = ref.strip()
                    if ref and 'HEAD' not in ref and 'origin/' not in ref:
                        target = ref
                        break
            if not target:
                target = sel['fullhash'][:7]
            if draw_menu(stdscr, " CHECKOUT ", [f"Checkout {target}?", "Yes", "Cancel"]) == 1:
                out = git_checkout(cwd, target)
                draw_menu(stdscr, " RESULT ", [out[:60] if out else "done!", "OK"])
        elif key == curses.KEY_PPAGE:
            selected_commit = max(0, selected_commit - 10)
            scroll = max(0, commit_indices[selected_commit] - text_height // 2)
        elif key == curses.KEY_NPAGE:
            selected_commit = min(len(commit_indices)-1, selected_commit + 10)
            sel_line = commit_indices[selected_commit]
            if sel_line >= scroll + text_height:
                scroll = sel_line - text_height + 1

# ─── Fuzzy Finder ─────────────────────────────────────────────────────────────

def fuzzy_find(stdscr, start_dir):
    stdscr.timeout(-1)
    current_dir = start_dir

    def get_files(d):
        files = [".."]
        try:
            entries = sorted(os.listdir(d))
            dirs_   = [e + "/" for e in entries if os.path.isdir(os.path.join(d, e))]
            files_  = [e for e in entries if os.path.isfile(os.path.join(d, e))]
            files  += dirs_ + files_
        except:
            pass
        return files

    all_files = get_files(current_dir)
    query     = ""
    selected  = 0

    while True:
        filtered = [f for f in all_files if query.lower() in f.lower()] if query else all_files
        selected = min(selected, max(0, len(filtered) - 1))

        height, width = stdscr.getmaxyx()
        panel_h = min(22, height - 4)
        panel_w = min(70, width - 4)
        y = (height - panel_h) // 2
        x = (width  - panel_w) // 2

        for i in range(panel_h):
            try:
                stdscr.addstr(y + i, x, " " * panel_w, curses.color_pair(COLOR_STATUSBAR))
            except:
                pass

        title = f" FIND FILE — {os.path.relpath(current_dir, start_dir) or '.'} "
        try:
            stdscr.addstr(y, x + (panel_w - len(title)) // 2, title[:panel_w-1],
                          curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD)
        except:
            pass

        list_h = panel_h - 3
        scroll  = max(0, selected - list_h + 1) if selected >= list_h else 0
        for i in range(list_h):
            fi = scroll + i
            if fi >= len(filtered):
                break
            f    = filtered[fi]
            attr = curses.color_pair(COLOR_STATUSBAR) | curses.A_REVERSE if fi == selected \
                   else curses.color_pair(COLOR_STATUSBAR)
            try:
                if f == "..":
                    stdscr.addstr(y + 1 + i, x + 1, ".. (go up)"[:panel_w-2].ljust(panel_w-2), attr)
                elif query and query.lower() in f.lower():
                    idx    = f.lower().index(query.lower())
                    before = f[:idx]
                    match  = f[idx:idx+len(query)]
                    after  = f[idx+len(query):]
                    sx = x + 1
                    stdscr.addstr(y + 1 + i, sx, before[:panel_w-2], attr)
                    sx += len(before)
                    if sx < x + panel_w - 1:
                        stdscr.addstr(y + 1 + i, sx, match[:panel_w-2], attr | curses.A_BOLD)
                        sx += len(match)
                    if sx < x + panel_w - 1:
                        stdscr.addstr(y + 1 + i, sx, after[:x+panel_w-1-sx], attr)
                else:
                    stdscr.addstr(y + 1 + i, x + 1, f[:panel_w-2].ljust(panel_w-2), attr)
            except:
                pass

        prompt = f" > {query}_"
        try:
            stdscr.addstr(y + panel_h - 2, x, prompt[:panel_w].ljust(panel_w),
                          curses.color_pair(COLOR_FIND))
        except:
            pass

        dirs_count  = sum(1 for f in filtered if f.endswith("/"))
        files_count = sum(1 for f in filtered if not f.endswith("/") and f != "..")
        hint = f" [Enter] open  [Tab] new tab  [Bksp] up dir  [Esc] cancel   {dirs_count}  {files_count} "
        try:
            stdscr.addstr(y + panel_h - 1, x, hint[:panel_w].ljust(panel_w),
                          curses.color_pair(COLOR_STATUSBAR))
        except:
            pass

        stdscr.refresh()
        key = stdscr.getch()

        if key == 27:
            stdscr.timeout(100)
            return None, False
        elif key in (curses.KEY_ENTER, 10, 13):
            if filtered and selected < len(filtered):
                chosen = filtered[selected]
                if chosen == "..":
                    current_dir = os.path.dirname(current_dir)
                    all_files   = get_files(current_dir)
                    query       = ""
                    selected    = 0
                elif chosen.endswith("/"):
                    current_dir = os.path.join(current_dir, chosen[:-1])
                    all_files   = get_files(current_dir)
                    query       = ""
                    selected    = 0
                else:
                    stdscr.timeout(100)
                    return os.path.join(current_dir, chosen), False
        elif key == 9:
            if filtered and selected < len(filtered):
                chosen = filtered[selected]
                if not chosen.endswith("/") and chosen != "..":
                    stdscr.timeout(100)
                    return os.path.join(current_dir, chosen), True
        elif key == curses.KEY_UP and selected > 0:
            selected -= 1
        elif key == curses.KEY_DOWN and selected < len(filtered) - 1:
            selected += 1
        elif key in (curses.KEY_BACKSPACE, 127, 8):
            if query:
                query    = query[:-1]
                selected = 0
            else:
                current_dir = os.path.dirname(current_dir)
                all_files   = get_files(current_dir)
                selected    = 0
        elif 32 <= key <= 126:
            query   += chr(key)
            selected = 0

    stdscr.timeout(100)
    return None, False

