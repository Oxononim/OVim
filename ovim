                nfg=draw_color_picker_256(stdscr,f" {ELEMENTS[selected][0]} — FG ",cfg)
                if nfg is None: continue
                nbg=draw_color_picker_256(stdscr,f" {ELEMENTS[selected][0]} — BG ",cbg)
                if nbg is None: continue
                na=draw_attrs_picker(stdscr,f" {ELEMENTS[selected][0]} ATTRS ",ca)
                if na is None: continue
                theme[elem_key]=(cp,nfg,nbg,na); apply_theme(stdscr); message=f"updated {ELEMENTS[selected][0]}"
        elif key in (ord('s'),ord('S')):
            name=prompt_input(stdscr," Save theme as: ")
            if name.strip(): message=f"saved to {save_theme_to_file(name.strip(),tab_size,word_wrap)}"
        elif key in (ord('l'),ord('L')):
            saved=list_saved_themes()
            if not saved: message="no saved themes!"
