def main(stdscr):
    curses.use_default_colors()
    curses.start_color()

    tab_size          = [4]
    word_wrap         = [False]
    autosave_interval = [0]

    # load config before applying theme so saved theme is used
    load_config(tab_size, word_wrap, autosave_interval)

    apply_theme(stdscr)
    curses.mousemask(curses.ALL_MOUSE_EVENTS)

    if len(sys.argv) == 1:
        draw_splash(stdscr)

    show_numbers   = True
    mode           = "normal"
    command        = ""
    message        = ""
    search_pattern = ""
    search_matches = []
    search_idx     = 0
    g_pending      = False
    z_pending      = False
    indent_pending = False
    dedent_pending = False
    dd_pending     = False
    yy_pending     = False
    yank_buffer    = ""
    branch         = None
    branch_timer   = 0
    mark_line      = None
    gutter_markers = {}
    gutter_timer   = 0
    panel          = RunPanel()
    panel_height   = 10
    panel_open     = False
    visual_start   = None
    autosave_timer = 0
    split_open     = False
    split_buf_idx  = 0
    split_active   = 0

    if len(sys.argv) > 1:
        buffers = [new_buffer(sys.argv[1])]
    else:
        buffers = [new_buffer()]
    current_buf = 0
    branch         = get_git_branch(buffers[current_buf]["filename"])
    gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])

    stdscr.timeout(100)

    while True:
        if split_open and split_active == 1:
            active_buf_idx = split_buf_idx
        else:
            active_buf_idx = current_buf

        buf         = buffers[active_buf_idx]
        lines       = buf["lines"]
        row         = buf["row"]
        col         = buf["col"]
        scroll_top  = buf["scroll_top"]
        scroll_left = buf.get("scroll_left", 0)

        branch_timer += 1
        if branch_timer >= 100:
            branch = get_git_branch(buf["filename"])
            branch_timer = 0

        gutter_timer += 1
        if gutter_timer >= 50:
            gutter_markers = get_gutter_markers(buf["filename"])
            gutter_timer = 0

        if autosave_interval[0] > 0:
            autosave_timer += 1
            if autosave_timer >= autosave_interval[0]:
                for b in buffers:
                    if b["modified"] and b["filename"]:
                        save(b["lines"], b["filename"])
                        b["modified"] = False
                autosave_timer = 0

        stdscr.erase()
        height, width = stdscr.getmaxyx()
        lang   = detect_language(buf["filename"], lines)
        offset = num_offset(len(lines), show_numbers)

        col = max(col, offset)
        buf["col"] = col

        draw_tabbar(stdscr, buffers, current_buf, width)

        if panel_open:
            total_text = max(4, height - 2 - panel_height - 1)
        else:
            total_text = height - 2

        if split_open:
            top_height = max(2, (total_text - 1) // 2)
            bot_height = max(2, total_text - top_height - 1)
            split_div  = top_height + 1
        else:
            top_height = total_text
            bot_height = 0
            split_div  = 0

        top_buf = buffers[current_buf]
        draw_lines(stdscr, top_buf["lines"], top_buf["scroll_top"], top_height,
                   num_offset(len(top_buf["lines"]), show_numbers), width,
                   detect_language(top_buf["filename"], top_buf["lines"]),
                   search_pattern, show_numbers, word_wrap[0], mark_line,
                   gutter_markers if split_active == 0 else {},
                   visual_start if split_active == 0 else None,
                   row if (split_active == 0 and mode == "visual") else None,
                   top_buf.get("scroll_left", 0), y_offset=1)

        if split_open:
            bot_buf  = buffers[split_buf_idx]
            bot_name = os.path.basename(bot_buf["filename"]) if bot_buf["filename"] else "[No Name]"
            if bot_buf["modified"]:
                bot_name += " ●"
            active_marker = " ◀ " if split_active == 1 else ""
            div_text = f"─── {bot_name}{active_marker}".ljust(width - 1, "─")
            try:
                stdscr.addstr(split_div, 0, div_text[:width-1], curses.color_pair(COLOR_PANEL))
            except:
                pass
            bot_offset = num_offset(len(bot_buf["lines"]), show_numbers)
            draw_lines(stdscr, bot_buf["lines"], bot_buf["scroll_top"], bot_height,
                       bot_offset, width,
                       detect_language(bot_buf["filename"], bot_buf["lines"]),
                       search_pattern, show_numbers, word_wrap[0], None,
                       gutter_markers if split_active == 1 else {},
                       visual_start if split_active == 1 else None,
                       row if (split_active == 1 and mode == "visual") else None,
                       bot_buf.get("scroll_left", 0), y_offset=split_div + 1)

        if panel_open:
            panel.draw(stdscr, total_text + 1, panel_height, width)

        if split_open and split_active == 1:
            bot_buf    = buffers[split_buf_idx]
            bot_offset = num_offset(len(bot_buf["lines"]), show_numbers)
            if word_wrap[0]:
                csr, csc = get_cursor_screen_row(
                    bot_buf["lines"], bot_buf["row"], bot_buf["col"],
                    bot_offset, width, bot_buf["scroll_top"], y_offset=split_div+1)
                csr = min(csr, split_div + bot_height)
            else:
                csr = bot_buf["row"] - bot_buf["scroll_top"] + split_div + 1
                csc = bot_buf["col"] - bot_buf.get("scroll_left", 0)
        else:
            if word_wrap[0]:
                csr, csc = get_cursor_screen_row(
                    lines, row, col, offset, width, scroll_top, y_offset=1)
                csr = min(csr, top_height)
            else:
                csr = row - scroll_top + 1
                csc = col - scroll_left

        if mode == "command":
            stdscr.addstr(height-1, 0, f":{command}    ", curses.color_pair(COLOR_STATUSBAR))
        elif mode == "search":
            stdscr.addstr(height-1, 0, f"/{search_pattern}    ", curses.color_pair(COLOR_STATUSBAR))
        else:
            draw_statusbar(stdscr, height, width, mode, buf, lang, col, offset,
                           message, tab_size[0], branch, word_wrap[0], mark_line,
                           visual_start, row, autosave_interval[0] > 0)

        try:
            stdscr.move(csr, max(0, csc))
        except:
            pass
        stdscr.refresh()

        key = stdscr.getch()
        if key == -1:
            continue
        message = ""

        if mode == "search":
            if key == 27:
                mode = "normal"
                search_pattern = ""
                search_matches = []
            elif key in (curses.KEY_ENTER, 10, 13):
                search_matches = get_search_matches(lines, search_pattern)
                if search_matches:
                    search_idx = 0
                    row, col   = search_matches[0]
                    col       += offset
                    buf["row"] = row
                    buf["col"] = col
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    message = f"/{search_pattern}  [{search_idx+1}/{len(search_matches)}]"
                else:
                    message = f"pattern not found: {search_pattern}"
                mode = "normal"
            elif key in (curses.KEY_BACKSPACE, 127, 8):
                search_pattern = search_pattern[:-1]
            elif 32 <= key <= 126:
                search_pattern += chr(key)
            continue

        if key == 3 and panel_open and panel.running:
            panel.stop()
            message = "process killed"
            continue

        if key == 23 and split_open:
            split_active = 1 - split_active
            continue

        if key == curses.KEY_MOUSE:
            try:
                _, mx, my, _, bstate = curses.getmouse()
                if bstate & curses.BUTTON1_CLICKED:
                    if split_open and my > split_div:
                        split_active = 1
                        bot_buf      = buffers[split_buf_idx]
                        bot_offset   = num_offset(len(bot_buf["lines"]), show_numbers)
                        new_row      = my - split_div - 1 + bot_buf["scroll_top"]
                        if 0 <= new_row < len(bot_buf["lines"]):
                            bot_buf["row"] = new_row
                            bot_buf["col"] = max(min(mx + bot_buf.get("scroll_left", 0),
                                                     len(bot_buf["lines"][new_row]) + bot_offset),
                                                 bot_offset)
                            bot_buf["scroll_top"] = clamp_scroll(new_row, bot_buf["scroll_top"], bot_height)
                    else:
                        split_active = 0
                        new_row = my - 1 + scroll_top
                        if 0 <= new_row < len(lines):
                            row = new_row
                            col = max(min(mx + scroll_left, len(lines[row]) + offset), offset)
                            buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                            buf["row"] = row
                            buf["col"] = col
                elif bstate & curses.BUTTON4_PRESSED:
                    row = max(0, row - 3)
                    col = max(min(col, len(lines[row]) + offset), offset)
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    buf["row"] = row
                    buf["col"] = col
                elif bstate & curses.BUTTON5_PRESSED:
                    row = min(len(lines) - 1, row + 3)
                    col = max(min(col, len(lines[row]) + offset), offset)
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    buf["row"] = row
                    buf["col"] = col
                elif bstate & (1 << 22):
                    if not word_wrap[0]:
                        buf["scroll_left"] = max(0, scroll_left - 3)
                elif bstate & (1 << 23):
                    if not word_wrap[0]:
                        max_left = max(0, max(len(l) for l in lines) - (width - offset))
                        buf["scroll_left"] = min(max_left, scroll_left + 3)
            except curses.error:
                pass

        elif key == curses.KEY_UP and row > 0:
            row -= 1
            col  = max(min(col, len(lines[row]) + offset), offset)
            buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
            buf["row"] = row
            buf["col"] = col
        elif key == curses.KEY_DOWN and row < len(lines) - 1:
            row += 1
            col  = max(min(col, len(lines[row]) + offset), offset)
            buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
            buf["row"] = row
            buf["col"] = col
        elif key == curses.KEY_LEFT and col > offset:
            col -= 1
            if not word_wrap[0] and col < scroll_left + offset:
                buf["scroll_left"] = max(0, scroll_left - 1)
            buf["col"] = col
        elif key == curses.KEY_RIGHT and col < len(lines[row]) + offset:
            col += 1
            if not word_wrap[0] and col - offset >= scroll_left + width - offset:
                buf["scroll_left"] = scroll_left + 1
            buf["col"] = col

        elif mode == "visual":
            if key == 27:
                mode = "normal"
                visual_start = None
            elif key in (ord('j'), curses.KEY_DOWN) and row < len(lines) - 1:
                row += 1
                buf["row"] = row
                buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
            elif key in (ord('k'), curses.KEY_UP) and row > 0:
                row -= 1
                buf["row"] = row
                buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
            elif key in (ord('y'), ord('Y')):
                sel_top      = min(visual_start, row)
                sel_bot      = max(visual_start, row)
                yank_buffer  = '\n'.join(lines[sel_top:sel_bot+1])
                copy_to_clipboard(yank_buffer)
                message      = f"yanked {sel_bot - sel_top + 1} lines"
                mode         = "normal"
                visual_start = None
            elif key == ord('d'):
                sel_top = min(visual_start, row)
                sel_bot = max(visual_start, row)
                push_undo(buf)
                del lines[sel_top:sel_bot+1]
                if not lines:
                    buf["lines"] = [""]
                row  = max(0, sel_top)
                col  = offset
                buf["row"]      = row
                buf["col"]      = col
                buf["modified"] = True
                buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                message      = f"deleted {sel_bot - sel_top + 1} lines"
                mode         = "normal"
                visual_start = None
            elif key == ord('>'):
                sel_top = min(visual_start, row)
                sel_bot = max(visual_start, row)
                push_undo(buf)
                for li in range(sel_top, sel_bot + 1):
                    lines[li] = " " * tab_size[0] + lines[li]
                buf["modified"] = True
                message = f"indented {sel_bot - sel_top + 1} lines"
            elif key == ord('<'):
                sel_top = min(visual_start, row)
                sel_bot = max(visual_start, row)
                push_undo(buf)
                for li in range(sel_top, sel_bot + 1):
                    lines[li] = lines[li][tab_size[0]:] \
                                 if lines[li].startswith(" " * tab_size[0]) \
                                 else lines[li].lstrip()
                buf["modified"] = True
                message = f"dedented {sel_bot - sel_top + 1} lines"

        elif mode == "normal":
            if key == ord(' '):
                open_theme_menu(stdscr, tab_size, word_wrap)
            elif key == ord('v'):
                visual_start = row
                mode         = "visual"
            elif key == ord('/'):
                mode           = "search"
                search_pattern = ""
            elif key == 4:  # Ctrl+D duplicate
                push_undo(buf)
                lines.insert(row + 1, lines[row])
                row += 1
                buf["row"]      = row
                buf["modified"] = True
                buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                message = "line duplicated"
            elif key == ord('>'):
                if indent_pending:
                    push_undo(buf)
                    lines[row]      = " " * tab_size[0] + lines[row]
                    buf["modified"] = True
                    message         = "indented"
                    indent_pending  = False
                else:
                    indent_pending = True
                    dedent_pending = False
            elif key == ord('<'):
                if dedent_pending:
                    push_undo(buf)
                    lines[row]      = lines[row][tab_size[0]:] \
                                      if lines[row].startswith(" " * tab_size[0]) \
                                      else lines[row].lstrip()
                    buf["modified"] = True
                    message         = "dedented"
                    dedent_pending  = False
                else:
                    dedent_pending = True
                    indent_pending = False
            elif key == ord('n') and not indent_pending and not dedent_pending:
                if search_matches:
                    search_idx = (search_idx + 1) % len(search_matches)
                    row, col   = search_matches[search_idx]
                    col       += offset
                    buf["row"] = row
                    buf["col"] = col
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    message = f"/{search_pattern}  [{search_idx+1}/{len(search_matches)}]"
                indent_pending = False
                dedent_pending = False
            elif key == ord('N'):
                indent_pending = False
                dedent_pending = False
                if search_matches:
                    search_idx = (search_idx - 1) % len(search_matches)
                    row, col   = search_matches[search_idx]
                    col       += offset
                    buf["row"] = row
                    buf["col"] = col
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    message = f"/{search_pattern}  [{search_idx+1}/{len(search_matches)}]"
            elif key == ord('u'):
                indent_pending = False
                dedent_pending = False
                if buf["undo_stack"]:
                    buf["redo_stack"].append((list(lines), row, col))
                    sl, sr, sc = buf["undo_stack"].pop()
                    buf["lines"] = sl
                    buf["row"]   = sr
                    buf["col"]   = sc
                    buf["scroll_top"] = clamp_scroll(sr, scroll_top, top_height)
                    message = "undone"
                else:
                    message = "nothing to undo"
            elif key == 18:  # Ctrl+R
                indent_pending = False
                dedent_pending = False
                if buf["redo_stack"]:
                    buf["undo_stack"].append((list(lines), row, col))
                    sl, sr, sc = buf["redo_stack"].pop()
                    buf["lines"] = sl
                    buf["row"]   = sr
                    buf["col"]   = sc
                    buf["scroll_top"] = clamp_scroll(sr, scroll_top, top_height)
                    message = "redone"
                else:
                    message = "nothing to redo"
            elif key == ord('g'):
                indent_pending = False
                dedent_pending = False
                if g_pending:
                    row        = 0
                    col        = offset
                    buf["row"] = row
                    buf["col"] = col
                    buf["scroll_top"] = 0
                    g_pending  = False
                else:
                    g_pending = True
                    z_pending = False
            elif key == ord('G'):
                indent_pending = False
                dedent_pending = False
                row        = len(lines) - 1
                col        = offset
                buf["row"] = row
                buf["col"] = col
                buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                g_pending  = False
            elif key == ord('z'):
                z_pending = not z_pending
                g_pending = False
            elif key == ord('h') and z_pending:
                if not word_wrap[0]:
                    buf["scroll_left"] = max(0, scroll_left - 5)
                z_pending = False
            elif key == ord('l') and z_pending:
                if not word_wrap[0]:
                    max_left = max(0, max(len(l) for l in lines) - (width - offset))
                    buf["scroll_left"] = min(max_left, scroll_left + 5)
                z_pending = False
            elif key == ord('t') and not z_pending and not g_pending:
                current_buf    = (current_buf + 1) % len(buffers)
                branch         = get_git_branch(buffers[current_buf]["filename"])
                gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                branch_timer   = 0
            elif key == ord('T') and not z_pending and not g_pending:
                current_buf    = (current_buf - 1) % len(buffers)
                branch         = get_git_branch(buffers[current_buf]["filename"])
                gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                branch_timer   = 0
            elif key == ord('i'):
                mode           = "insert"
                dd_pending     = False
                yy_pending     = False
                g_pending      = False
                z_pending      = False
                indent_pending = False
                dedent_pending = False
            elif key == ord(':'):
                mode           = "command"
                command        = ""
                g_pending      = False
                z_pending      = False
                indent_pending = False
                dedent_pending = False
            elif key == ord('h') and not z_pending:
                if col > offset:
                    col -= 1
                    buf["col"] = col
            elif key == ord('l') and not z_pending:
                if col < len(lines[row]) + offset:
                    col += 1
                    buf["col"] = col
            elif key == ord('j'):
                indent_pending = False
                dedent_pending = False
                if row < len(lines) - 1:
                    row += 1
                    col  = max(min(col, len(lines[row]) + offset), offset)
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    buf["row"] = row
                    buf["col"] = col
            elif key == ord('k'):
                indent_pending = False
                dedent_pending = False
                if row > 0:
                    row -= 1
                    col  = max(min(col, len(lines[row]) + offset), offset)
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    buf["row"] = row
                    buf["col"] = col
            elif key == ord('o'):
                indent_pending = False
                dedent_pending = False
                push_undo(buf)
                lines.insert(row + 1, "")
                row            = row + 1
                col            = offset
                mode           = "insert"
                buf["modified"] = True
                buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                buf["row"] = row
                buf["col"] = col
            elif key == ord('x'):
                indent_pending = False
                dedent_pending = False
                if col - offset < len(lines[row]):
                    push_undo(buf)
                    lines[row]      = lines[row][:col-offset] + lines[row][col-offset+1:]
                    buf["modified"] = True
            elif key == ord('p'):
                indent_pending = False
                dedent_pending = False
                text = yank_buffer if yank_buffer else paste_from_clipboard()
                if text:
                    push_undo(buf)
                    paste_lines = text.split('\n')
                    for j, pl in enumerate(paste_lines):
                        lines.insert(row + 1 + j, pl)
                    row = row + len(paste_lines)
                    col = offset
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    buf["modified"] = True
                    buf["row"] = row
                    buf["col"] = col
                    message = "pasted"
            elif key == ord('P'):
                indent_pending = False
                dedent_pending = False
                text = yank_buffer if yank_buffer else paste_from_clipboard()
                if text:
                    push_undo(buf)
                    paste_lines = text.split('\n')
                    for j, pl in enumerate(paste_lines):
                        lines.insert(row + j, pl)
                    col = offset
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    buf["modified"] = True
                    buf["col"] = col
                    message = "pasted above"
            elif key == ord('d'):
                indent_pending = False
                dedent_pending = False
                if dd_pending:
                    push_undo(buf)
                    if len(lines) > 1:
                        lines.pop(row)
                        if row >= len(lines):
                            row -= 1
                    else:
                        buf["lines"] = [""]
                    col = offset
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    buf["modified"] = True
                    buf["row"] = row
                    buf["col"] = col
                    dd_pending = False
                else:
                    dd_pending = True
                    yy_pending = False
            elif key == ord('y'):
                indent_pending = False
                dedent_pending = False
                if yy_pending:
                    yank_buffer = lines[row]
                    copy_to_clipboard(yank_buffer)
                    message     = "line yanked!"
                    yy_pending  = False
                else:
                    yy_pending = True
                    dd_pending = False
            elif key == 27:
                dd_pending     = False
                yy_pending     = False
                g_pending      = False
                z_pending      = False
                indent_pending = False
                dedent_pending = False
                mark_line      = None
                visual_start   = None
                search_pattern = ""
                search_matches = []

        elif mode == "insert":
            if key == 27:
                mode       = "normal"
                dd_pending = False
                yy_pending = False
            elif key == 9:
                push_undo(buf)
                tab        = " " * tab_size[0]
                lines[row] = lines[row][:col-offset] + tab + lines[row][col-offset:]
                col       += tab_size[0]
                buf["modified"] = True
                buf["col"]      = col
            elif key in (curses.KEY_BACKSPACE, 127, 8):
                push_undo(buf)
                if col > offset:
                    lines[row]      = lines[row][:col-offset-1] + lines[row][col-offset:]
                    col            -= 1
                    buf["modified"] = True
                    buf["col"]      = col
                elif row > 0:
                    col             = len(lines[row - 1]) + offset
                    lines[row - 1]  = lines[row - 1] + lines[row]
                    lines.pop(row)
                    row            -= 1
                    buf["modified"] = True
                    buf["row"]      = row
                    buf["col"]      = col
                    buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
            elif key in (curses.KEY_ENTER, 10, 13):
                push_undo(buf)
                indent     = get_auto_indent(lines[row], lang)
                new_line   = lines[row][col-offset:]
                lines[row] = lines[row][:col-offset]
                lines.insert(row + 1, indent + new_line)
                row        = row + 1
                col        = offset + len(indent)
                buf["modified"] = True
                buf["row"]      = row
                buf["col"]      = col
                buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
            elif 32 <= key <= 126:
                push_undo(buf)
                ch = chr(key)
                if ch in PAIRS:
                    closing    = PAIRS[ch]
                    lines[row] = lines[row][:col-offset] + ch + closing + lines[row][col-offset:]
                    col       += 1
                else:
                    lines[row] = lines[row][:col-offset] + ch + lines[row][col-offset:]
                    col       += 1
                buf["modified"] = True
                buf["col"]      = col

        elif mode == "command":
            if key == 27:
                mode    = "normal"
                command = ""
            elif key in (curses.KEY_ENTER, 10, 13):
                cwd = get_git_root(buf["filename"])

                if command == "w":
                    if save(lines, buf["filename"]):
                        buf["modified"] = False
                        branch         = get_git_branch(buf["filename"])
                        gutter_markers = get_gutter_markers(buf["filename"])
                        message        = f"saved to {buf['filename']}"
                    else:
                        message = "no filename!"
                elif command == "q":
                    if buf["modified"]:
                        message = "unsaved changes! use :q! to force or :wq to save"
                    elif len(buffers) > 1:
                        buffers.pop(current_buf)
                        current_buf = min(current_buf, len(buffers) - 1)
                        if split_buf_idx >= len(buffers):
                            split_buf_idx = len(buffers) - 1
                        branch         = get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                    else:
                        save_config(tab_size, word_wrap, autosave_interval)
                        break
                elif command == "q!":
                    panel.stop()
                    if len(buffers) > 1:
                        buffers.pop(current_buf)
                        current_buf = min(current_buf, len(buffers) - 1)
                        if split_buf_idx >= len(buffers):
                            split_buf_idx = len(buffers) - 1
                        branch         = get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                    else:
                        save_config(tab_size, word_wrap, autosave_interval)
                        break
                elif command == "wq":
                    save(lines, buf["filename"])
                    buf["modified"] = False
                    panel.stop()
                    if len(buffers) > 1:
                        buffers.pop(current_buf)
                        current_buf = min(current_buf, len(buffers) - 1)
                        if split_buf_idx >= len(buffers):
                            split_buf_idx = len(buffers) - 1
                        branch         = get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                    else:
                        save_config(tab_size, word_wrap, autosave_interval)
                        break
                elif command.startswith("w "):
                    buf["filename"] = command[2:]
                    save(lines, buf["filename"])
                    buf["modified"] = False
                    branch         = get_git_branch(buf["filename"])
                    gutter_markers = get_gutter_markers(buf["filename"])
                    message        = f"saved to {buf['filename']}"
                elif command == "tabnew":
                    buffers.append(new_buffer())
                    current_buf    = len(buffers) - 1
                    branch         = get_git_branch(buffers[current_buf]["filename"])
                    gutter_markers = {}
                elif command.startswith("tabnew "):
                    buffers.append(new_buffer(command[7:]))
                    current_buf    = len(buffers) - 1
                    branch         = get_git_branch(buffers[current_buf]["filename"])
                    gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                elif command == "find":
                    start_dir = get_git_root(buf["filename"]) or \
                                (os.path.dirname(os.path.abspath(buf["filename"]))
                                 if buf["filename"] else os.getcwd())
                    filepath, new_tab = fuzzy_find(stdscr, start_dir)
                    if filepath:
                        if new_tab:
                            buffers.append(new_buffer(filepath))
                            current_buf = len(buffers) - 1
                        else:
                            buffers[current_buf] = new_buffer(filepath)
                        branch         = get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers = get_gutter_markers(buffers[current_buf]["filename"])
                        message        = f"opened {os.path.basename(filepath)}"
                elif command == "split":
                    split_open    = True
                    split_buf_idx = current_buf
                    split_active  = 0
                    message       = "split opened — Ctrl+W to switch"
                elif command.startswith("split ") and command != "split close":
                    fname = command[6:].strip()
                    buffers.append(new_buffer(fname))
                    split_buf_idx = len(buffers) - 1
                    split_open    = True
                    split_active  = 0
                    message       = f"split: {os.path.basename(fname)}"
                elif command == "split close":
                    split_open   = False
                    split_active = 0
                    message      = "split closed"
                elif command.startswith("rename "):
                    new_name = command[7:].strip()
                    if new_name and buf["filename"]:
                        new_path = os.path.join(
                            os.path.dirname(os.path.abspath(buf["filename"])), new_name)
                        try:
                            os.rename(buf["filename"], new_path)
                            buf["filename"] = new_path
                            branch         = get_git_branch(buf["filename"])
                            gutter_markers = get_gutter_markers(buf["filename"])
                            message        = f"renamed to {new_name}"
                        except Exception as e:
                            message = f"rename failed: {e}"
                    else:
                        message = "usage: :rename newname"
                elif command.startswith("replace "):
                    parts = command[8:].split(' ', 1)
                    if len(parts) == 2:
                        old, new_str = parts
                        push_undo(buf)
                        count = 0
                        for i, line in enumerate(lines):
                            new_line = line.replace(old, new_str)
                            if new_line != line:
                                lines[i] = new_line
                                count   += 1
                        buf["modified"] = True
                        message = f"replaced {count} occurrence{'s' if count != 1 else ''}"
                    else:
                        message = "usage: :replace old new"
                elif command.startswith("set tabsize "):
                    try:
                        tab_size[0] = max(1, int(command[12:]))
                        message     = f"tab size set to {tab_size[0]}"
                    except ValueError:
                        message = "invalid tab size"
                elif command.startswith("set autosave "):
                    try:
                        secs                  = int(command[13:])
                        autosave_interval[0]  = max(0, secs) * 10
                        autosave_timer        = 0
                        message = f"autosave {'OFF' if secs == 0 else f'every {secs}s'}"
                    except ValueError:
                        message = "usage: :set autosave N"
                elif command == "set wrap":
                    word_wrap[0] = True
                    message      = "word wrap ON"
                elif command == "set nowrap":
                    word_wrap[0]       = False
                    buf["scroll_left"] = 0
                    message            = "word wrap OFF"
                elif command == "run":
                    if buf["filename"]:
                        panel_open = True
                        panel.start(buf["filename"], lang)
                        message = f"running {os.path.basename(buf['filename'])}..."
                    else:
                        message = "no file to run — save first!"
                elif command == "run close":
                    panel.stop()
                    panel_open = False
                    message    = "panel closed"
                elif command == "h":
                    draw_scrollable(stdscr, HELP_LINES, " OVIM HELP ")
                elif command == "gl":
                    git_tree(stdscr, cwd)
                    apply_theme(stdscr)
                    branch = get_git_branch(buf["filename"])
                elif command == "gs":
                    if cwd:
                        out, err = git_run(['status'], cwd=cwd)
                        draw_scrollable(stdscr, (out or err).splitlines(), " GIT STATUS ")
                    else:
                        message = "not a git repo"
                elif command == "gd":
                    if buf["filename"] and cwd:
                        out, err = git_run(['diff', buf["filename"]], cwd=cwd)
                        if out:
                            draw_scrollable(stdscr, out.splitlines(),
                                f" GIT DIFF — {os.path.basename(buf['filename'])} ")
                        else:
                            message = "no changes to show"
                    else:
                        message = "no file open"
                elif command == "ga":
                    if buf["filename"] and cwd:
                        out, err       = git_run(['add', buf["filename"]], cwd=cwd)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        message        = f"staged {os.path.basename(buf['filename'])}" if not err else err
                    else:
                        message = "no file open"
                elif command == "gaa":
                    if cwd:
                        out, err       = git_run(['add', '-A'], cwd=cwd)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        message        = "staged all files" if not err else err
                    else:
                        message = "not a git repo"
                elif command == "gun":
                    if buf["filename"] and cwd:
                        out, err       = git_run(['restore', '--staged', buf["filename"]], cwd=cwd)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        message        = f"unstaged {os.path.basename(buf['filename'])}" if not err else err
                    else:
                        message = "no file open"
                elif command == "gc":
                    if cwd:
                        commit_msg = prompt_input(stdscr, " Commit message: ")
                        if commit_msg.strip():
                            out, err       = git_run(['commit', '-m', commit_msg.strip()], cwd=cwd)
                            git_result_popup(stdscr, " GIT COMMIT ", out, err)
                            branch         = get_git_branch(buf["filename"])
                            gutter_markers = get_gutter_markers(buf["filename"])
                        else:
                            message = "commit cancelled"
                    else:
                        message = "not a git repo"
                elif command == "gca":
                    if cwd:
                        commit_msg = prompt_input(stdscr, " Commit message: ")
                        if commit_msg.strip():
                            git_run(['add', '-A'], cwd=cwd)
                            out, err       = git_run(['commit', '-m', commit_msg.strip()], cwd=cwd)
                            git_result_popup(stdscr, " GIT COMMIT ALL ", out, err)
                            branch         = get_git_branch(buf["filename"])
                            gutter_markers = get_gutter_markers(buf["filename"])
                        else:
                            message = "commit cancelled"
                    else:
                        message = "not a git repo"
                elif command == "gp":
                    if cwd:
                        stdscr.addstr(height-1, 0, " pushing...".ljust(width-1),
                                      curses.color_pair(COLOR_STATUSBAR))
                        stdscr.refresh()
                        out, err = git_run(['push'], cwd=cwd)
                        git_result_popup(stdscr, " GIT PUSH ", out, err)
                    else:
                        message = "not a git repo"
                elif command == "gpl":
                    if cwd:
                        stdscr.addstr(height-1, 0, " pulling...".ljust(width-1),
                                      curses.color_pair(COLOR_STATUSBAR))
                        stdscr.refresh()
                        out, err = git_run(['pull'], cwd=cwd)
                        git_result_popup(stdscr, " GIT PULL ", out, err)
                        if buf["filename"] and os.path.exists(buf["filename"]):
                            with open(buf["filename"], 'r') as f:
                                content = f.read().splitlines()
                            if content:
                                buf["lines"] = content
                            buf["modified"] = False
                        gutter_markers = get_gutter_markers(buf["filename"])
                        branch         = get_git_branch(buf["filename"])
                    else:
                        message = "not a git repo"
                elif command == "gf":
                    if cwd:
                        stdscr.addstr(height-1, 0, " fetching...".ljust(width-1),
                                      curses.color_pair(COLOR_STATUSBAR))
                        stdscr.refresh()
                        out, err = git_run(['fetch'], cwd=cwd)
                        git_result_popup(stdscr, " GIT FETCH ", out, err)
                    else:
                        message = "not a git repo"
                elif command == "gb":
                    if cwd:
                        new_branch = prompt_input(stdscr, " New branch name: ")
                        if new_branch.strip():
                            out, err = git_run(['checkout', '-b', new_branch.strip()], cwd=cwd)
                            git_result_popup(stdscr, " GIT BRANCH ", out, err)
                            branch   = get_git_branch(buf["filename"])
                        else:
                            message = "cancelled"
                    else:
                        message = "not a git repo"
                elif command == "gbd":
                    if cwd:
                        branches = get_git_branches(cwd)
                        if branches:
                            labels = [("* " if cur else "  ") + n for n, cur in branches] + ["Cancel"]
                            idx    = draw_menu(stdscr, " DELETE BRANCH ", labels)
                            if idx is not None and idx < len(branches):
                                bname = branches[idx][0]
                                if draw_menu(stdscr, " ARE YOU SURE? ",
                                             [f"Delete {bname}", "Cancel"]) == 0:
                                    out, err = git_run(['branch', '-d', bname], cwd=cwd)
                                    git_result_popup(stdscr, " GIT BRANCH DELETE ", out, err)
                                    branch   = get_git_branch(buf["filename"])
                        else:
                            message = "no branches found"
                    else:
                        message = "not a git repo"
                elif command == "gsw":
                    if cwd:
                        branches = get_git_branches(cwd)
                        if branches:
                            labels = [("* " if cur else "  ") + n for n, cur in branches] + ["Cancel"]
                            idx    = draw_menu(stdscr, " SWITCH BRANCH ", labels)
                            if idx is not None and idx < len(branches):
                                bname  = branches[idx][0]
                                out, err = git_run(['checkout', bname], cwd=cwd)
                                git_result_popup(stdscr, " GIT SWITCH ", out, err)
                                branch         = get_git_branch(buf["filename"])
                                gutter_markers = get_gutter_markers(buf["filename"])
                                if buf["filename"] and os.path.exists(buf["filename"]):
                                    with open(buf["filename"], 'r') as f:
                                        content = f.read().splitlines()
                                    if content:
                                        buf["lines"] = content
                                    buf["modified"] = False
                        else:
                            message = "no branches found"
                    else:
                        message = "not a git repo"
                elif command == "gst":
                    if cwd:
                        out, err       = git_run(['stash'], cwd=cwd)
                        git_result_popup(stdscr, " GIT STASH ", out, err)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        if buf["filename"] and os.path.exists(buf["filename"]):
                            with open(buf["filename"], 'r') as f:
                                content = f.read().splitlines()
                            if content:
                                buf["lines"] = content
                            buf["modified"] = False
                    else:
                        message = "not a git repo"
                elif command == "gstp":
                    if cwd:
                        out, err       = git_run(['stash', 'pop'], cwd=cwd)
                        git_result_popup(stdscr, " GIT STASH POP ", out, err)
                        gutter_markers = get_gutter_markers(buf["filename"])
                        if buf["filename"] and os.path.exists(buf["filename"]):
                            with open(buf["filename"], 'r') as f:
                                content = f.read().splitlines()
                            if content:
                                buf["lines"] = content
                            buf["modified"] = False
                    else:
                        message = "not a git repo"
                elif command == "md":
                    if mark_line is None:
                        mark_line = row
                        message   = f"mark set at line {mark_line+1} -- move cursor and :md again to delete"
                    else:
                        start = min(mark_line, row)
                        end   = max(mark_line, row)
                        push_undo(buf)
                        del lines[start:end + 1]
                        if not lines:
                            buf["lines"] = [""]
                        row             = max(0, start)
                        col             = offset
                        buf["row"]      = row
                        buf["col"]      = col
                        buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                        buf["modified"] = True
                        message         = f"deleted lines {start+1} to {end+1}"
                        mark_line       = None
                elif command.startswith("goto "):
                    try:
                        n          = int(command[5:]) - 1
                        row        = max(0, min(n, len(lines) - 1))
                        col        = offset
                        buf["row"] = row
                        buf["col"] = col
                        buf["scroll_top"] = clamp_scroll(row, scroll_top, top_height)
                    except ValueError:
                        message = "invalid line number"
                else:
                    message = f"unknown command: {command}"

                mode    = "normal"
                command = ""
            elif key in (curses.KEY_BACKSPACE, 127, 8):
                command = command[:-1]
            elif 32 <= key <= 126:
                command += chr(key)

    panel.stop()

curses.wrapper(main)