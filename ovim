def lang_field_wizard(stdscr, field, current=""):
    """Guided prompt for a single language regex field. Returns value or ''."""
    title, example, tip = LANG_FIELD_HELP[field]
    height, width = stdscr.getmaxyx()
    pw = min(72, width-4); ph = 9
    y = (height-ph)//2; x = (width-pw)//2
    while True:
        for i in range(ph):
            try: stdscr.addstr(y+i, x, " "*pw, tcp("statusbar"))
            except: pass
        try:
            stdscr.addstr(y+1, x+2, title[:pw-4],  tcp("statusbar")|curses.A_BOLD)
            stdscr.addstr(y+2, x+2, example[:pw-4], tcp("comment"))
            stdscr.addstr(y+3, x+2, tip[:pw-4],     tcp("comment"))
            stdscr.addstr(y+4, x+2, ("current: "+current)[:pw-4] if current else "(blank = skip this field)", tcp("normal"))
            stdscr.addstr(y+6, x+2, " [Enter] keep current  [type] new pattern  [Esc] skip "[:pw-4], tcp("statusbar"))
        except: pass
        # Draw inline prompt
        prompt = f" > {current}_"
        try: stdscr.addstr(y+5, x, prompt[:pw].ljust(pw), tcp("find"))
        except: pass
        stdscr.refresh()
        # Now do inline input
        stdscr.timeout(-1); curses.curs_set(1)
        curses.echo(); stdscr.move(y+5, x+3+len(current))
        try: typed = stdscr.getstr(y+5, x+3, pw-6).decode()
        except: typed = ""
        curses.noecho(); stdscr.timeout(100)
        return typed if typed.strip() else current


