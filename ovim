# ─── Config ───────────────────────────────────────────────────────────────────

def load_config(tab_size, word_wrap, autosave_interval):
    global custom_langs
    if not os.path.exists(CONFIG_PATH): return
    try:
        with open(CONFIG_PATH,'r') as f: data = json.load(f)
        if "tab_size"          in data: tab_size[0]          = int(data["tab_size"])
        if "word_wrap"         in data: word_wrap[0]         = bool(data["word_wrap"])
        if "autosave_interval" in data: autosave_interval[0] = int(data["autosave_interval"])
        if "custom_langs"      in data: custom_langs         = data["custom_langs"]
        if "theme" in data:
            for key, val in data["theme"].items():
                if key in theme and isinstance(val, dict):
                    def pc(v):
                        if isinstance(v, int): return v
                        return {"Default":-1,"Black":0,"Red":1,"Green":2,"Yellow":3,
                                "Blue":4,"Magenta":5,"Cyan":6,"White":7}.get(v,-1)
                    theme[key] = (val.get("pair",theme[key][0]),
                                  pc(val.get("fg",-1)), pc(val.get("bg",-1)),
                                  val.get("attrs",0))
    except: pass

def save_config(tab_size, word_wrap, autosave_interval):
    os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
    data = {
        "tab_size": tab_size[0], "word_wrap": word_wrap[0],
        "autosave_interval": autosave_interval[0], "custom_langs": custom_langs,
        "theme": {k:{"pair":p,"fg":fg,"bg":bg,"attrs":a} for k,(p,fg,bg,a) in theme.items()}
    }
    try:
        with open(CONFIG_PATH,'w') as f: json.dump(data, f, indent=2)
    except: pass

# ─── Undo Tree ────────────────────────────────────────────────────────────────
# Each node stores a PRE-EDIT snapshot.
# push_undo(buf) is called BEFORE an edit.
# ut_undo stores the CURRENT buffer state as node.fwd, then restores node's snapshot.
# ut_redo restores node.fwd (the post-edit state).

def push_undo(buf):
    node = {
        "id":       buf["ut_next_id"],
        "lines":    list(buf["lines"]),
        "row":      buf["row"],
        "col":      buf["col"],
        "parent":   buf["ut_current"],
        "children": [],
        "ts":       datetime.datetime.now().strftime("%H:%M:%S"),
        "fwd":      None,
    }
    buf["ut_next_id"] += 1
    cur = buf["ut_current"]
    if cur is None:
        root = {"id":-1,"lines":list(buf["lines"]),"row":buf["row"],"col":buf["col"],
                "parent":None,"children":[node],"ts":"initial","fwd":None}
        node["parent"] = root
        buf["ut_root"]    = root
    else:
        cur["children"].append(node)
    buf["ut_current"] = node

def ut_undo(buf):
    node = buf["ut_current"]
    if node is None or node["parent"] is None: return "nothing to undo"
    # Save the current (post-edit) state into the node so redo can restore it
    node["fwd"] = (list(buf["lines"]), buf["row"], buf["col"])
    node["parent"]["_last_child"] = node
    # Restore the pre-edit snapshot stored in node
    buf["lines"] = list(node["lines"])
    buf["row"]   = node["row"]
    buf["col"]   = node["col"]
    buf["ut_current"] = node["parent"]
    buf["modified"]   = True
    return "undone"

def ut_redo(buf):
    node = buf["ut_current"]
    if node is None or not node["children"]: return "nothing to redo"
    last = node.get("_last_child")
    if last not in node["children"]: last = node["children"][-1]
    if last["fwd"] is None: return "nothing to redo"
    fl, fr, fc = last["fwd"]
    buf["lines"] = list(fl)
    buf["row"]   = fr
    buf["col"]   = fc
    last["parent"]["_last_child"] = last
    buf["ut_current"] = last
    buf["modified"]   = True
    return "redone"

def ut_redo_pick(buf, stdscr):
    """Redo with branch picker if multiple branches."""
    node = buf["ut_current"]
    if node is None or not node["children"]: return "nothing to redo"
    valid = [c for c in node["children"] if c.get("fwd") is not None]
    if not valid: return "nothing to redo"
    if len(valid) == 1:
        last = valid[0]
    else:
        labels = [f"branch {c['id']}  ({c['ts']})" for c in valid] + ["Cancel"]
        idx = draw_menu(stdscr, " CHOOSE REDO BRANCH ", labels)
        if idx is None or idx >= len(valid): return "redo cancelled"
        last = valid[idx]
    fl, fr, fc = last["fwd"]
    buf["lines"] = list(fl)
    buf["row"]   = fr
    buf["col"]   = fc
    last["parent"]["_last_child"] = last
    buf["ut_current"] = last
    buf["modified"]   = True
    return f"redone → branch {last['id']}"

def draw_undo_tree(stdscr, buf):
    root = buf.get("ut_root")
    cur  = buf.get("ut_current")
    if root is None:
        draw_menu(stdscr, " UNDO TREE ", ["No history yet.", "OK"]); return ""

    # Flatten tree DFS
    entries = []
    def dfs(node, depth, prefix_parts):
        is_cur  = node is cur
        has_fwd = bool(node.get("fwd"))
        n_kids  = len(node.get("children",[]))
        entries.append((node, depth, is_cur, has_fwd, n_kids, list(prefix_parts)))
        kids = node.get("children",[])
        for i, child in enumerate(kids):
            last = (i == len(kids)-1)
            new_parts = prefix_parts + [("└" if last else "├")]
            dfs(child, depth+1, new_parts)
    dfs(root, 0, [])

    selected = next((i for i,(n,*_) in enumerate(entries) if n is cur), 0)
    scroll   = 0

    while True:
        stdscr.erase(); height, width = stdscr.getmaxyx()
        stdscr.addstr(0, 0, " UNDO TREE  [:undotree]  [Enter] jump  [q] close ".center(width)[:width-1],
                      tcp("statusbar")|curses.A_BOLD)
        list_h = height-3
        if selected < scroll:           scroll = selected
        if selected >= scroll+list_h:   scroll = selected-list_h+1
        scroll = max(0, min(scroll, max(0,len(entries)-list_h)))

        for i in range(list_h):
            ei = scroll+i
            if ei >= len(entries): break
            node, depth, is_cur, has_fwd, n_kids, pfx = entries[ei]
            branch_mark = "⑂" if n_kids > 1 else " "
            cur_mark    = "▶" if is_cur else " "
            fwd_mark    = "↑" if has_fwd else " "
            nid = node["id"] if node["id"] >= 0 else "root"
            ts  = node.get("ts","")
            prefix_str = "".join(pfx)
            label = f" {cur_mark}{branch_mark}{fwd_mark} {prefix_str}#{nid} {ts}"
            attr = tcp("statusbar")|curses.A_REVERSE if ei==selected else tcp("normal")
            try: stdscr.addstr(i+1, 0, label[:width-1].ljust(min(width-1,60)), attr)
            except: pass

        legend = " ▶=current  ⑂=branch  ↑=has-redo  [↑↓] move  [Enter] jump  [q] close "
        stdscr.addstr(height-1, 0, legend.ljust(width-1)[:width-1], tcp("statusbar"))
        stdscr.refresh()

        key = stdscr.getch()
        if key in (ord('q'),ord('Q'),27): return ""
        elif key == curses.KEY_UP   and selected > 0:               selected -= 1
        elif key == curses.KEY_DOWN and selected < len(entries)-1:  selected += 1
        elif key in (curses.KEY_ENTER,10,13):
            node = entries[selected][0]
            # Jump: prefer fwd state (post-edit), else node's stored state
            if node.get("fwd"):
                fl,fr,fc = node["fwd"]
                buf["lines"]=list(fl); buf["row"]=fr; buf["col"]=fc
            else:
                buf["lines"]=list(node["lines"]); buf["row"]=node["row"]; buf["col"]=node["col"]
            buf["ut_current"] = node
            buf["modified"]   = True
            return f"jumped to #{node['id'] if node['id']>=0 else 'root'}"
    return ""

