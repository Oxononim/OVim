def draw_graph_line(stdscr,y,graph,hash_,refs,msg,author,date,selected,width):
    if selected: stdscr.attron(curses.A_REVERSE)
    x=0
    for ch in graph:
        if x>=width-1: break
        attr=tcp("git_graph") if ch in '|/\\*' else tcp("normal")
        if selected: attr|=curses.A_REVERSE
        try: stdscr.addch(y,x,ch,attr)
        except: pass
        x+=1
    if hash_:
        try: stdscr.addstr(y,x,f" {hash_}"[:width-x-1],tcp("git_hash")|(curses.A_REVERSE if selected else 0))
        except: pass
        x+=len(f" {hash_}")
        if refs:
            for ref in [r.strip() for r in refs.split(',') if r.strip()]:
                if x>=width-2: break
                rs=f" ({ref})"
                try: stdscr.addstr(y,x,rs[:width-x-1],tcp("git_ref")|(curses.A_REVERSE if selected else 0))
                except: pass
                x+=len(rs)
        if msg and x<width-1:
            try: stdscr.addstr(y,x,f" {msg}"[:width-x-1],tcp("normal")|(curses.A_REVERSE if selected else 0))
            except: pass
    if selected: stdscr.attroff(curses.A_REVERSE)

def git_tree(stdscr,cwd):
    if not cwd: draw_menu(stdscr," GIT TREE ",["Not a git repo!","OK"]); return
    stdscr.erase(); height,width=stdscr.getmaxyx()
    stdscr.addstr(height//2,max(0,(width-20)//2)," loading git log... ",tcp("statusbar")); stdscr.refresh()
    entries=get_git_log(cwd)
    if not entries: draw_menu(stdscr," GIT TREE ",["No commits found!","OK"]); return
    commit_indices=[i for i,e in enumerate(entries) if e['hash']]
    if not commit_indices: draw_menu(stdscr," GIT TREE ",["No commits found!","OK"]); return
    selected_commit=0; scroll=0
    while True:
        stdscr.erase(); height,width=stdscr.getmaxyx(); text_height=height-2
        stdscr.addstr(0,0," GIT TREE ".center(width)[:width-1],tcp("statusbar")|curses.A_BOLD)
        for i in range(text_height):
            ei=scroll+i
            if ei>=len(entries): break
            e=entries[ei]; is_sel=ei in commit_indices and commit_indices.index(ei)==selected_commit
            draw_graph_line(stdscr,i+1,e['graph'],e['hash'],e['refs'],e['msg'],e['author'],e['date'],is_sel,width)
        sel=entries[commit_indices[selected_commit]]
        bottom=f" [{sel['hash']}] {sel['msg'][:35]}  [Enter] diff  [b] branches  [c] checkout  [q] quit "
        stdscr.addstr(height-1,0,bottom[:width-1],tcp("statusbar")); stdscr.refresh()
        key=stdscr.getch()
        if key in (ord('q'),ord('Q'),27): break
        elif key==curses.KEY_UP and selected_commit>0:
            selected_commit-=1
            if commit_indices[selected_commit]<scroll: scroll=commit_indices[selected_commit]
        elif key==curses.KEY_DOWN and selected_commit<len(commit_indices)-1:
            selected_commit+=1; sl=commit_indices[selected_commit]
            if sl>=scroll+text_height: scroll=sl-text_height+1
        elif key in (curses.KEY_ENTER,10,13):
            if sel['fullhash']:
                wf=draw_scrollable(stdscr,get_commit_diff(cwd,sel['fullhash']).splitlines(),
                    f" COMMIT {sel['hash']} ","[Enter] full diff  ")
                if wf: draw_scrollable(stdscr,get_commit_full_diff(cwd,sel['fullhash']).splitlines(),f" FULL DIFF {sel['hash']} ")
        elif key==ord('b'):
            branches=get_git_branches(cwd)
            if branches:
                labels=[("* " if cur else "  ")+n for n,cur in branches]+["Cancel"]
                idx=draw_menu(stdscr," BRANCHES ",labels)
                if idx is not None and idx<len(branches):
                    bname=branches[idx][0]
                    for ci,e in enumerate(entries):
                        if e['hash'] and bname in e['refs'] and ci in commit_indices:
                            selected_commit=commit_indices.index(ci); scroll=max(0,ci-text_height//2); break
        elif key==ord('c'):
            target=None
            if sel['refs']:
                for ref in sel['refs'].split(','):
                    ref=ref.strip()
                    if ref and 'HEAD' not in ref and 'origin/' not in ref: target=ref; break
            if not target: target=sel['fullhash'][:7]
            if draw_menu(stdscr," CHECKOUT ",[f"Checkout {target}?","Yes","Cancel"])==1:
                out=git_checkout(cwd,target); draw_menu(stdscr," RESULT ",[out[:60] if out else "done!","OK"])
        elif key==curses.KEY_PPAGE:
            selected_commit=max(0,selected_commit-10); scroll=max(0,commit_indices[selected_commit]-text_height//2)
        elif key==curses.KEY_NPAGE:
            selected_commit=min(len(commit_indices)-1,selected_commit+10); sl=commit_indices[selected_commit]
            if sl>=scroll+text_height: scroll=sl-text_height+1

# ─── Fuzzy finder ─────────────────────────────────────────────────────────────

def fuzzy_find(stdscr,start_dir):
    stdscr.timeout(-1); current_dir=start_dir
    def get_files(d):
        files=[".."]
        try:
            entries=sorted(os.listdir(d))
            files+=[e+"/" for e in entries if os.path.isdir(os.path.join(d,e))]
            files+=[e for e in entries if os.path.isfile(os.path.join(d,e))]
        except: pass
        return files
    all_files=get_files(current_dir); query=""; selected=0
    while True:
        filtered=[f for f in all_files if query.lower() in f.lower()] if query else all_files
        selected=min(selected,max(0,len(filtered)-1))
        height,width=stdscr.getmaxyx()
        ph=min(22,height-4); pw=min(70,width-4)
        y=(height-ph)//2; x=(width-pw)//2
        for i in range(ph):
            try: stdscr.addstr(y+i,x," "*pw,tcp("statusbar"))
            except: pass
        title=f" FIND FILE — {os.path.relpath(current_dir,start_dir) or '.'} "
        try: stdscr.addstr(y,x+(pw-len(title))//2,title[:pw-1],tcp("statusbar")|curses.A_BOLD)
        except: pass
        list_h=ph-3; lscroll=max(0,selected-list_h+1) if selected>=list_h else 0
        for i in range(list_h):
            fi=lscroll+i
            if fi>=len(filtered): break
            f=filtered[fi]; attr=tcp("statusbar")|curses.A_REVERSE if fi==selected else tcp("statusbar")
            try:
                if f=="..": stdscr.addstr(y+1+i,x+1,".. (go up)"[:pw-2].ljust(pw-2),attr)
                elif query and query.lower() in f.lower():
                    idx=f.lower().index(query.lower()); before=f[:idx]; match=f[idx:idx+len(query)]; after=f[idx+len(query):]
                    sx=x+1; stdscr.addstr(y+1+i,sx,before[:pw-2],attr); sx+=len(before)
                    if sx<x+pw-1: stdscr.addstr(y+1+i,sx,match[:pw-2],attr|curses.A_BOLD); sx+=len(match)
                    if sx<x+pw-1: stdscr.addstr(y+1+i,sx,after[:x+pw-1-sx],attr)
                else: stdscr.addstr(y+1+i,x+1,f[:pw-2].ljust(pw-2),attr)
            except: pass
        try:
            stdscr.addstr(y+ph-2,x,f" > {query}_"[:pw].ljust(pw),tcp("find"))
            dc=sum(1 for f in filtered if f.endswith("/")); fc=sum(1 for f in filtered if not f.endswith("/") and f!="..")
            stdscr.addstr(y+ph-1,x,f" [Enter] open  [Tab] new tab  [Bksp] up  [Esc] cancel   {dc}  {fc} "[:pw].ljust(pw),tcp("statusbar"))
        except: pass
        stdscr.refresh()
        key=stdscr.getch()
        if key==27: stdscr.timeout(100); return None,False
        elif key in (curses.KEY_ENTER,10,13):
            if filtered and selected<len(filtered):
                chosen=filtered[selected]
                if chosen=="..": current_dir=os.path.dirname(current_dir); all_files=get_files(current_dir); query=""; selected=0
                elif chosen.endswith("/"): current_dir=os.path.join(current_dir,chosen[:-1]); all_files=get_files(current_dir); query=""; selected=0
                else: stdscr.timeout(100); return os.path.join(current_dir,chosen),False
        elif key==9:
            if filtered and selected<len(filtered):
                chosen=filtered[selected]
                if not chosen.endswith("/") and chosen!="..": stdscr.timeout(100); return os.path.join(current_dir,chosen),True
        elif key==curses.KEY_UP and selected>0: selected-=1
        elif key==curses.KEY_DOWN and selected<len(filtered)-1: selected+=1
        elif key in (curses.KEY_BACKSPACE,127,8):
            if query: query=query[:-1]; selected=0
            else: current_dir=os.path.dirname(current_dir); all_files=get_files(current_dir); selected=0
        elif 32<=key<=126: query+=chr(key); selected=0
    stdscr.timeout(100); return None,False

