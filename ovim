class RunPanel:
    def __init__(self):
        self.output=[];self.running=False;self.proc=None;self.thread=None
        self.scroll=0;self.lock=threading.Lock()

    def start(self, filename, lang):
        self.stop()
        with self.lock: self.output=[]; self.scroll=0
        self.running=True
        if lang=="python":   cmd=["python3", filename]
        elif lang=="bash":   cmd=["/bin/bash", filename]
        elif lang=="json":   cmd=["python3","-m","json.tool",filename]
        elif lang and lang.startswith("custom_"):
            ext=lang[7:]
            cmd=custom_langs.get(ext,{}).get("run","").split() or None
        else: cmd=None
        if not cmd:
            with self.lock: self.output.append(f"don't know how to run: {filename}")
            self.running=False; return
        def run():
            try:
                self.proc=subprocess.Popen(cmd,stdout=subprocess.PIPE,stderr=subprocess.STDOUT,text=True,bufsize=1)
                for line in self.proc.stdout:
                    with self.lock: self.output.append(line.rstrip())
                self.proc.wait()
                with self.lock:
                    self.output.append(""); self.output.append(f"  [process exited with code {self.proc.returncode}]")
            except Exception as e:
                with self.lock: self.output.append(f"error: {e}")
            finally: self.running=False
        self.thread=threading.Thread(target=run,daemon=True); self.thread.start()

    def stop(self):
        if self.proc:
            try: self.proc.terminate(); self.proc=None
            except: pass
        self.running=False

    def get_output(self):
        with self.lock: return list(self.output)

    def draw(self, stdscr, top, height, width, x_off=0, pane_w=None):
        if pane_w is None: pane_w=width-x_off
        status=" RUNNING..." if self.running else " DONE "
        title=f" OUTPUT {status}"; hint=" [:run close]  [Ctrl+C] kill "
        padding=max(0,pane_w-len(title)-len(hint))
        try: stdscr.addstr(top,x_off,(title+" "*padding+hint)[:pane_w-1],tcp("panel"))
        except: pass
        lines=self.get_output()
        if self.running: self.scroll=max(0,len(lines)-(height-1))
        for i, line in enumerate(lines[self.scroll:self.scroll+height-1]):
            if any(w in line.lower() for w in ('error','traceback','exception')): color=tcp("diff_del")
            elif any(w in line.lower() for w in ('warning','warn')): color=tcp("gutter_mod")
            elif line.startswith("  [process exited"): color=tcp("panel")
            else: color=tcp("normal")
            try: stdscr.addstr(top+1+i,x_off,line[:pane_w-1],color)
            except: pass

