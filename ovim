def theme_builder(stdscr, tab_size, word_wrap):
    selected = 0
    message  = ""
    while True:
        stdscr.erase()
        height, width = stdscr.getmaxyx()
        preview_w = width // 2
        side_w    = width - preview_w - 1

        stdscr.addstr(0, 0, " THEME BUILDER ".center(width),
                      curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD)
        stdscr.addstr(1, 0, " PREVIEW".ljust(preview_w), curses.color_pair(COLOR_STATUSBAR))

        _, elem_key  = ELEMENTS[selected]
        preview_mode = ELEMENT_PREVIEW.get(elem_key, "syntax")
        draw_preview(stdscr, 2, 0, height - 4, preview_w - 1, preview_mode, word_wrap[0])

        for i in range(1, height - 2):
            stdscr.addstr(i, preview_w, "│", curses.color_pair(COLOR_NORMAL))

        stdscr.addstr(1, preview_w + 1, " ELEMENTS".ljust(side_w), curses.color_pair(COLOR_STATUSBAR))

        list_h = height - 5
        scroll  = max(0, selected - list_h + 1) if selected >= list_h else 0

        for i in range(list_h):
            ei = scroll + i
            if ei >= len(ELEMENTS):
                break
            label, key = ELEMENTS[ei]
            if key == "__wrap__":
                entry = f" {label}: {'ON' if word_wrap[0] else 'OFF'}"
                color = COLOR_STATUSBAR
            else:
                pair, fg, bg = theme[key]
                entry = f" {label}: {COLOR_ID_TO_NAME.get(fg,'Default')}/{COLOR_ID_TO_NAME.get(bg,'Default')}"
                color = pair
            attr = curses.color_pair(COLOR_STATUSBAR) | curses.A_REVERSE if ei == selected \
                   else curses.color_pair(color)
            try:
                stdscr.addstr(2 + i, preview_w + 1, entry.ljust(side_w), attr)
            except:
                pass

        if len(ELEMENTS) > list_h:
            pct = int((selected / (len(ELEMENTS) - 1)) * list_h)
            try:
                stdscr.addstr(2 + pct, preview_w, "█", curses.color_pair(COLOR_STATUSBAR))
            except:
                pass

        bottom = " [Enter] Edit/Toggle  [S] Save  [L] Load  [D] Delete  [T] Tab  [Q] Done"
        if message:
            bottom = f" {message}"
        stdscr.addstr(height-2, 0, bottom.ljust(width-1), curses.color_pair(COLOR_STATUSBAR))
        stdscr.refresh()

        key     = stdscr.getch()
        message = ""

        if key == curses.KEY_UP and selected > 0:
            selected -= 1
        elif key == curses.KEY_DOWN and selected < len(ELEMENTS) - 1:
            selected += 1
        elif key in (curses.KEY_ENTER, 10, 13):
            _, elem_key = ELEMENTS[selected]
            if elem_key == "__wrap__":
                word_wrap[0] = not word_wrap[0]
                message = f"word wrap {'ON' if word_wrap[0] else 'OFF'}"
                continue
            new_fg = draw_color_picker(stdscr, f" {ELEMENTS[selected][0]} FG ")
            if new_fg is None:
                continue
            new_bg = draw_color_picker(stdscr, f" {ELEMENTS[selected][0]} BG ")
            if new_bg is None:
                continue
            theme[elem_key] = (theme[elem_key][0], new_fg, new_bg)
            apply_theme(stdscr)
        elif key in (ord('s'), ord('S')):
            name = prompt_input(stdscr, " Save theme as: ")
            if name.strip():
                message = f"saved to {save_theme_to_file(name.strip(), tab_size, word_wrap)}"
        elif key in (ord('l'), ord('L')):
            saved = list_saved_themes()
            if not saved:
                message = "no saved themes found!"
            else:
                idx = draw_menu(stdscr, " LOAD THEME ", saved + ["Cancel"])
                if idx is not None and idx < len(saved):
                    if load_theme_from_file(saved[idx], tab_size, word_wrap):
                        apply_theme(stdscr)
                        message = f"loaded {saved[idx]}"
        elif key in (ord('d'), ord('D')):
            saved = list_saved_themes()
            if not saved:
                message = "no saved themes found!"
            else:
                idx = draw_menu(stdscr, " DELETE THEME ", saved + ["Cancel"])
                if idx is not None and idx < len(saved):
                    if draw_menu(stdscr, " ARE YOU SURE? ", ["Yes, delete it", "Cancel"]) == 0:
                        os.remove(os.path.join(THEME_DIR, f"{saved[idx]}.json"))
                        message = f"deleted {saved[idx]}"
        elif key in (ord('t'), ord('T')):
            val = prompt_input(stdscr, " Tab size: ")
            try:
                tab_size[0] = max(1, int(val.strip()))
                message = f"tab size set to {tab_size[0]}"
            except ValueError:
                message = "invalid tab size"
        elif key in (ord('q'), ord('Q'), 27):
            break

def open_theme_menu(stdscr, tab_size, word_wrap):
    choice = draw_menu(stdscr, " THEME ", ["Presets", "Customize", "Theme Builder", "Cancel"])
    if choice is None or choice == 3:
        return
    if choice == 0:
        preset_names = list(PRESETS.keys())
        idx = draw_menu(stdscr, " PRESETS ", preset_names + ["Cancel"])
        if idx is not None and idx < len(preset_names):
            for key, val in PRESETS[preset_names[idx]].items():
                theme[key] = val
            apply_theme(stdscr)
    elif choice == 1:
        labels = [e[0] for e in ELEMENTS] + ["Done"]
        while True:
            idx = draw_menu(stdscr, " CUSTOMIZE ", labels)
            if idx is None or idx == len(ELEMENTS):
                break
            _, key = ELEMENTS[idx]
            if key == "__wrap__":
                word_wrap[0] = not word_wrap[0]
                continue
            new_fg = draw_color_picker(stdscr, f" {ELEMENTS[idx][0]} FG ")
            if new_fg is None:
                continue
            new_bg = draw_color_picker(stdscr, f" {ELEMENTS[idx][0]} BG ")
            if new_bg is None:
                continue
            theme[key] = (theme[key][0], new_fg, new_bg)
            apply_theme(stdscr)
    elif choice == 2:
        theme_builder(stdscr, tab_size, word_wrap)

def detect_language(filename, lines):
    if filename:
        ext = os.path.splitext(filename)[1]
        if ext == ".py":
            return "python"
        elif ext == ".sh":
            return "bash"
        elif ext == ".json":
            return "json"
    if lines and lines[0].startswith("#!"):
        shebang = lines[0].lower()
        if "python" in shebang:
            return "python"
        elif "bash" in shebang or "sh" in shebang:
            return "bash"
    return None

def get_auto_indent(line, lang):
    indent         = len(line) - len(line.lstrip())
    current_indent = line[:indent]
    stripped       = line.rstrip()
    if lang == "python" and stripped.endswith(":"):
        return current_indent + "    "
    elif lang == "bash" and stripped.endswith(("then", "do", "{", "()")):
        return current_indent + "    "
    elif lang == "json" and stripped.endswith(("{", "[")):
        return current_indent + "  "
    return current_indent

def copy_to_clipboard(text):
    try:
        subprocess.run(['wl-copy'], input=text.encode(), check=True)
    except:
        pass

def paste_from_clipboard():
    try:
        return subprocess.run(['wl-paste', '--no-newline'],
                              capture_output=True).stdout.decode()
    except:
        return ""

def save(lines, filename):
    if filename:
        with open(filename, 'w') as f:
            f.write('\n'.join(lines))
        return True
    return False

def num_offset(total_lines, show_numbers):
    if show_numbers:
        return len(str(total_lines)) + 1
    return 0

def clamp_scroll(row, scroll_top, height):
    if row < scroll_top:
        scroll_top = row
    elif row >= scroll_top + height - 1:
        scroll_top = row - height + 2
    return scroll_top

def push_undo(buf):
    buf["undo_stack"].append((list(buf["lines"]), buf["row"], buf["col"]))
    buf["redo_stack"].clear()

def draw_tabbar(stdscr, buffers, current, width):
    x = 0
    for i, buf in enumerate(buffers):
        name = os.path.basename(buf["filename"]) if buf["filename"] else "[No Name]"
        if buf["modified"]:
            name += " ●"
        label = f" {name} "
        if x + len(label) > width:
            break
        attr = curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD if i == current \
               else curses.color_pair(COLOR_NORMAL) | curses.A_REVERSE
        stdscr.addstr(0, x, label, attr)
        x += len(label)
        stdscr.addstr(0, x, "│", curses.color_pair(COLOR_NORMAL))
        x += 1

def draw_statusbar(stdscr, height, width, mode, buf, lang, col, offset,
                   message, tab_size, branch, word_wrap, mark_line,
                   visual_start, row, autosave_on):
    lines    = buf["lines"]
    now      = datetime.datetime.now().strftime("%a %d %b %H:%M")
    words    = sum(len(l.split()) for l in lines)
    filename = buf["filename"]

    if message:
        left = f" {message} "
    else:
        left = f" -- {mode.upper()} -- {filename or '[No Name]'} "
        if mark_line is not None:
            left += f"[MARK:{mark_line+1}] "
        if mode == "visual" and visual_start is not None:
            sel_top = min(visual_start, row)
            sel_bot = max(visual_start, row)
            left += f"[{sel_bot - sel_top + 1} lines] "

    as_str = "  " if autosave_on else ""
    right  = f"{as_str}{lang or 'plain'}  {words}w  tab:{tab_size}  {'wrap  ' if word_wrap else ''}ln {row+1}/{len(lines)}  col {col-offset+1}  {now} "

    try:
        if branch:
            branch_label = f" {branch} "
            stdscr.addstr(height-1, 0, left[:width-1], curses.color_pair(COLOR_STATUSBAR))
            bx = len(left)
            if bx < width - 1:
                stdscr.addstr(height-1, bx, PL_RIGHT, curses.color_pair(COLOR_GITBRANCH))
                bx += 1
            if bx < width - 1:
                stdscr.addstr(height-1, bx, branch_label[:width-bx-1],
                              curses.color_pair(COLOR_GITBRANCH))
                bx += len(branch_label)
            if bx < width - 1:
                stdscr.addstr(height-1, bx, PL_RIGHT, curses.color_pair(COLOR_STATUSBAR))
                bx += 1
            if bx < width - 1:
                padding = max(0, width - bx - len(right) - 1)
                stdscr.addstr(height-1, bx, (" " * padding + right)[:width-bx-1],
                              curses.color_pair(COLOR_STATUSBAR))
        else:
            padding = max(0, width - len(left) - len(right))
            stdscr.addstr(height-1, 0, (left + " " * padding + right)[:width-1],
                          curses.color_pair(COLOR_STATUSBAR))
    except:
        pass

def wrap_line(line, width, offset):
    text_width = width - offset
    if text_width <= 0 or len(line) <= text_width:
        return [line]
    chunks = []
    while line:
        chunks.append(line[:text_width])
        line = line[text_width:]
    return chunks

def draw_lines(stdscr, lines, scroll_top, text_height, offset, width, lang,
               search_pattern, show_numbers, word_wrap, mark_line, gutter_markers,
               visual_start, visual_end, scroll_left=0, y_offset=1):
    total   = len(lines)
    num_w   = len(str(total))
    sel_top = min(visual_start, visual_end) if visual_start is not None and visual_end is not None else -1
    sel_bot = max(visual_start, visual_end) if visual_start is not None and visual_end is not None else -1

    if word_wrap:
        screen_row = y_offset
        for li in range(scroll_top, total):
            if screen_row >= text_height + y_offset:
                break
            chunks = wrap_line(lines[li], width, offset)
            for ci, chunk in enumerate(chunks):
                if screen_row >= text_height + y_offset:
                    break
                x = 0
                if show_numbers:
                    if ci == 0:
                        num = str(li + 1).rjust(num_w) + " "
                        if li == mark_line:
                            nc = COLOR_MARK
                        elif (li + 1) in gutter_markers:
                            m  = gutter_markers[li + 1]
                            nc = COLOR_GUTTER_ADD if m == '+' else \
                                 COLOR_GUTTER_MOD if m == '~' else COLOR_GUTTER_DEL
                        else:
                            nc = COLOR_LINENR
                        stdscr.addstr(screen_row, 0, num, curses.color_pair(nc))
                    else:
                        stdscr.addstr(screen_row, 0, " " * offset, curses.color_pair(COLOR_LINENR))
                    x = offset
                if sel_top <= li <= sel_bot:
                    try:
                        stdscr.addstr(screen_row, x, chunk[:width-x], curses.color_pair(COLOR_VISUAL))
                    except:
                        pass
                else:
                    for text, color in highlight_line(chunk, lang, search_pattern or None):
                        if x < width:
                            stdscr.addstr(screen_row, x, text[:width - x], curses.color_pair(color))
                            x += len(text)
                screen_row += 1
        while screen_row < text_height + y_offset:
            stdscr.addstr(screen_row, 0, "~", curses.color_pair(COLOR_TILDE))
            screen_row += 1
    else:
        visible = lines[scroll_top:scroll_top + text_height]
        for i, line in enumerate(visible):
            li = scroll_top + i
            x  = 0
            if show_numbers:
                num = str(li + 1).rjust(num_w) + " "
                if li == mark_line:
                    nc = COLOR_MARK
                elif (li + 1) in gutter_markers:
                    m  = gutter_markers[li + 1]
                    nc = COLOR_GUTTER_ADD if m == '+' else \
                         COLOR_GUTTER_MOD if m == '~' else COLOR_GUTTER_DEL
                else:
                    nc = COLOR_LINENR
                stdscr.addstr(i + y_offset, 0, num, curses.color_pair(nc))
                x = offset
            if sel_top <= li <= sel_bot:
                display = line[scroll_left:] if scroll_left < len(line) else ""
                try:
                    stdscr.addstr(i + y_offset, x, display[:width-x], curses.color_pair(COLOR_VISUAL))
                except:
                    pass
            else:
                display = line[scroll_left:] if scroll_left < len(line) else ""
                for text, color in highlight_line(display, lang, search_pattern or None):
                    if x < width:
                        stdscr.addstr(i + y_offset, x, text[:width - x], curses.color_pair(color))
                        x += len(text)
        for i in range(len(visible), text_height):
            stdscr.addstr(i + y_offset, 0, "~", curses.color_pair(COLOR_TILDE))

def get_cursor_screen_row(lines, row, col, offset, width, scroll_top, y_offset=1):
    screen_row = y_offset
    text_width = width - offset
    for li in range(scroll_top, row):
        screen_row += len(wrap_line(lines[li], width, offset))
    if text_width > 0:
        char_col  = col - offset
        chunk_idx = max(0, char_col // text_width)
        screen_row += chunk_idx
        screen_col  = offset + (char_col % text_width)
    else:
        screen_col = col
    return screen_row, screen_col

