def main(stdscr):
    curses.use_default_colors(); curses.start_color()
    tab_size=[4]; word_wrap=[False]; autosave_interval=[0]
    load_config(tab_size,word_wrap,autosave_interval)
    apply_theme(stdscr); init_picker_pairs()
    curses.mousemask(curses.ALL_MOUSE_EVENTS)
    if len(sys.argv)==1: draw_splash(stdscr)

    show_numbers=True; autocaps_on=False
    mode="normal"; command=""; message=""
    search_pattern=""; search_matches=[]; search_idx=0
    g_pending=False; z_pending=False; indent_pending=False; dedent_pending=False
    dd_pending=False; yy_pending=False
    branch=None; branch_timer=0; mark_line=None; gutter_markers={}; gutter_timer=0
    panel=RunPanel(); panel_height=10; panel_open=False
    visual_start=None; autosave_timer=0; preferred_vis_col=0
    split_open=False; split_buf_idx=0; split_active=0
    split_orientation="H"; split_ratio=0.5; split_fullscreen=False

    if len(sys.argv)>1: buffers=[new_buffer(sys.argv[1])]
    else: buffers=[new_buffer()]
    current_buf=0
    branch=get_git_branch(buffers[current_buf]["filename"])
    gutter_markers=get_gutter_markers(buffers[current_buf]["filename"])
    stdscr.timeout(100)

    while True:
        active_buf_idx=split_buf_idx if (split_open and split_active==1) else current_buf
        buf=buffers[active_buf_idx]; lines=buf["lines"]
        row=buf["row"]; col=buf["col"]
        scroll_top=buf["scroll_top"]; scroll_left=buf.get("scroll_left",0)

        branch_timer+=1
        if branch_timer>=100: branch=get_git_branch(buf["filename"]); branch_timer=0
        gutter_timer+=1
        if gutter_timer>=50: gutter_markers=get_gutter_markers(buf["filename"]); gutter_timer=0
        if autosave_interval[0]>0:
            autosave_timer+=1
            if autosave_timer>=autosave_interval[0]:
                for b in buffers:
                    if b["modified"] and b["filename"]: save(b["lines"],b["filename"]); b["modified"]=False
                autosave_timer=0

        stdscr.erase(); height,width=stdscr.getmaxyx()
        lang=detect_language(buf["filename"],lines)
        offset=num_offset(len(lines),show_numbers)
        col=max(col,offset); buf["col"]=col
        draw_tabbar(stdscr,buffers,current_buf,width)
        total_text=max(4,height-2-panel_height-1) if panel_open else height-2

        # Layout
        if split_open and not split_fullscreen:
            if split_orientation=="H":
                primary_h=max(2,int(total_text*split_ratio))
                secondary_h=max(2,total_text-primary_h-1)
                primary_w=secondary_w=width; primary_x=secondary_x=0
                divider_y=primary_h+1; divider_x=None
            else:
                primary_w=max(4,int(width*split_ratio))
                secondary_w=max(4,width-primary_w-1)
                primary_h=secondary_h=total_text
                primary_x=0; secondary_x=primary_w+1
                divider_y=None; divider_x=primary_w
        elif split_open and split_fullscreen:
            primary_h=secondary_h=total_text; primary_w=secondary_w=width
            primary_x=secondary_x=0; divider_y=divider_x=None
        else:
            primary_h=total_text; primary_w=width; primary_x=0
            secondary_h=secondary_w=secondary_x=0; divider_y=divider_x=None

        top_buf=buffers[current_buf]; top_offset=num_offset(len(top_buf["lines"]),show_numbers)
        if not (split_open and split_fullscreen and split_active==1):
            draw_lines(stdscr,top_buf["lines"],top_buf["scroll_top"],primary_h,
                       top_offset,primary_w,detect_language(top_buf["filename"],top_buf["lines"]),
                       search_pattern,show_numbers,word_wrap[0],mark_line,
                       gutter_markers if split_active==0 else {},
                       visual_start if split_active==0 else None,
                       (row,col) if (split_active==0 and mode=="visual") else None,
                       top_buf.get("scroll_left",0),y_offset=1,x_offset=primary_x,pane_width=primary_w)

        if split_open:
            bot_buf=buffers[split_buf_idx]
