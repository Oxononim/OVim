def draw_tabbar(stdscr,buffers,current,width):
    x=0
    for i,buf in enumerate(buffers):
        name=os.path.basename(buf["filename"]) if buf["filename"] else "[No Name]"
        if buf["modified"]: name+=" ●"
        label=f" {name} "
        if x+len(label)>width: break
        attr=tcp("statusbar")|curses.A_BOLD if i==current else tcp("normal")|curses.A_REVERSE
        stdscr.addstr(0,x,label,attr); x+=len(label)
        stdscr.addstr(0,x,"│",tcp("normal")); x+=1

def draw_statusbar(stdscr,height,width,mode,buf,lang,col,offset,
                   message,tab_size,branch,word_wrap,mark_line,
                   visual_start,row,autosave_on,autocaps_on):
    lines=buf["lines"]; now=datetime.datetime.now().strftime("%a %d %b %H:%M")
    words=sum(len(l.split()) for l in lines); filename=buf["filename"]
    if message: left=f" {message} "
    else:
        left=f" -- {mode.upper()} -- {filename or '[No Name]'} "
        if mark_line is not None: left+=f"[MARK:{mark_line+1}] "
        if mode=="visual" and visual_start is not None:
            r1,c1=visual_start; r2,c2=row,col
            if r1>r2 or (r1==r2 and c1>c2): r1,c1,r2,c2=r2,c2,r1,c1
            left+=f"[{abs(c2-c1)} chars] " if r1==r2 else f"[{r2-r1+1} lines] "
    flags=("  " if autosave_on else "")+("Aa " if autocaps_on else "")
    right=f"{flags}{lang or 'plain'}  {words}w  tab:{tab_size}  {'wrap  ' if word_wrap else ''}ln {row+1}/{len(lines)}  col {col-offset+1}  {now} "
    try:
        if branch:
            bl=f" {branch} "; stdscr.addstr(height-1,0,left[:width-1],tcp("statusbar"))
            bx=len(left)
            if bx<width-1: stdscr.addstr(height-1,bx,PL_RIGHT,tcp("gitbranch")); bx+=1
            if bx<width-1: stdscr.addstr(height-1,bx,bl[:width-bx-1],tcp("gitbranch")); bx+=len(bl)
            if bx<width-1: stdscr.addstr(height-1,bx,PL_RIGHT,tcp("statusbar")); bx+=1
            if bx<width-1:
                padding=max(0,width-bx-len(right)-1)
                stdscr.addstr(height-1,bx,(" "*padding+right)[:width-bx-1],tcp("statusbar"))
        else:
            padding=max(0,width-len(left)-len(right))
            stdscr.addstr(height-1,0,(left+" "*padding+right)[:width-1],tcp("statusbar"))
    except: pass

def draw_lines(stdscr,lines,scroll_top,text_height,offset,width,lang,
               search_pattern,show_numbers,word_wrap,mark_line,gutter_markers,
               visual_start,visual_end,scroll_left=0,y_offset=1,x_offset=0,pane_width=None):
    if pane_width is None: pane_width=width-x_offset
    total=len(lines); num_w=len(str(total))

    def gutter(li):
        ns=str(li+1).rjust(num_w)
        if li==mark_line: return ns[:-1]+"X ",("mark")
        if (li+1) in gutter_markers:
            m=gutter_markers[li+1]
            return ns+" ",("gutter_add" if m=='+' else "gutter_mod" if m=='~' else "gutter_del")
        return ns+" ","linenr"

    if word_wrap:
        screen_row=y_offset
        for li in range(scroll_top,total):
            if screen_row>=text_height+y_offset: break
            chunks=wrap_line(lines[li],pane_width,offset)
            for ci,chunk in enumerate(chunks):
                if screen_row>=text_height+y_offset: break
                if show_numbers:
                    if ci==0:
                        num,nc=gutter(li)
                        try: stdscr.addstr(screen_row,x_offset,num,tcp(nc))
                        except: pass
                    else:
                        try: stdscr.addstr(screen_row,x_offset," "*offset,tcp("linenr"))
                        except: pass
                x=x_offset+offset; abs_start=ci*(pane_width-offset); char_pos=0
                for text,cid in highlight_line(chunk,lang,search_pattern or None):
                    tk=COLOR_ID_TO_THEME_KEY.get(cid,"normal"); p,fg,bg,a=theme[tk]
                    for ch in text:
                        if x>=x_offset+pane_width: break
                        in_sel=char_in_selection(li,abs_start+char_pos,visual_start,visual_end,offset)
                        try: stdscr.addch(screen_row,x,ch,tcp("visual") if in_sel else (curses.color_pair(p)|a))
                        except: pass
                        x+=1; char_pos+=1
                screen_row+=1
        while screen_row<text_height+y_offset:
            try: stdscr.addstr(screen_row,x_offset,"~",tcp("tilde"))
            except: pass
            screen_row+=1
    else:
        visible=lines[scroll_top:scroll_top+text_height]
        for i,line in enumerate(visible):
            li=scroll_top+i
            if show_numbers:
                num,nc=gutter(li)
                try: stdscr.addstr(i+y_offset,x_offset,num,tcp(nc))
                except: pass
            x=x_offset+offset; display=line[scroll_left:] if scroll_left<len(line) else ""; char_pos=scroll_left
            for text,cid in highlight_line(display,lang,search_pattern or None):
                tk=COLOR_ID_TO_THEME_KEY.get(cid,"normal"); p,fg,bg,a=theme[tk]
                for ch in text:
                    if x>=x_offset+pane_width: break
                    in_sel=char_in_selection(li,char_pos,visual_start,visual_end,offset)
                    try: stdscr.addch(i+y_offset,x,ch,tcp("visual") if in_sel else (curses.color_pair(p)|a))
                    except: pass
                    x+=1; char_pos+=1
        for i in range(len(visible),text_height):
            try: stdscr.addstr(i+y_offset,x_offset,"~",tcp("tilde"))
            except: pass

def get_cursor_screen_row(lines,row,col,offset,pane_width,scroll_top,y_offset=1):
    tw=max(1,pane_width-offset); screen_row=y_offset
    for li in range(scroll_top,row):
        n=max(1,-(-max(1,len(lines[li]))//tw)) if lines[li] else 1
        screen_row+=n
    tc=max(0,col-offset); screen_row+=tc//tw; screen_col=offset+(tc%tw)
    return screen_row,screen_col

