                        branch=get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers=get_gutter_markers(buffers[current_buf]["filename"])
                    else: save_config(tab_size,word_wrap,autosave_interval); break
                elif command=="q!":
                    panel.stop()
                    if len(buffers)>1:
                        buffers.pop(current_buf); current_buf=min(current_buf,len(buffers)-1)
                        if split_buf_idx>=len(buffers): split_buf_idx=len(buffers)-1
                        branch=get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers=get_gutter_markers(buffers[current_buf]["filename"])
                    else: save_config(tab_size,word_wrap,autosave_interval); break
                elif command=="wq":
                    save(lines,buf["filename"]); buf["modified"]=False; panel.stop()
                    if len(buffers)>1:
                        buffers.pop(current_buf); current_buf=min(current_buf,len(buffers)-1)
                        if split_buf_idx>=len(buffers): split_buf_idx=len(buffers)-1
                        branch=get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers=get_gutter_markers(buffers[current_buf]["filename"])
                    else: save_config(tab_size,word_wrap,autosave_interval); break
                elif command.startswith("w "):
                    buf["filename"]=command[2:]; save(lines,buf["filename"]); buf["modified"]=False
                    branch=get_git_branch(buf["filename"]); gutter_markers=get_gutter_markers(buf["filename"])
                    message=f"saved to {buf['filename']}"
                elif command=="tabnew":
                    buffers.append(new_buffer()); current_buf=len(buffers)-1
                    branch=get_git_branch(buffers[current_buf]["filename"]); gutter_markers={}
                elif command.startswith("tabnew "):
                    buffers.append(new_buffer(command[7:])); current_buf=len(buffers)-1
                    branch=get_git_branch(buffers[current_buf]["filename"])
                    gutter_markers=get_gutter_markers(buffers[current_buf]["filename"])
                elif command=="find":
                    start_dir=get_git_root(buf["filename"]) or \
                              (os.path.dirname(os.path.abspath(buf["filename"])) if buf["filename"] else os.getcwd())
                    fp,new_tab=fuzzy_find(stdscr,start_dir)
                    if fp:
                        if new_tab: buffers.append(new_buffer(fp)); current_buf=len(buffers)-1
                        else: buffers[current_buf]=new_buffer(fp)
                        branch=get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers=get_gutter_markers(buffers[current_buf]["filename"])
                        message=f"opened {os.path.basename(fp)}"

                # Splits
                elif command in ("split","sp"):
                    split_open=True; split_buf_idx=current_buf; split_active=0
                    split_orientation="H"; message="split — Ctrl+W switch  [ ] resize  _ fullscreen"
                elif command.startswith("split ") and command not in ("split close","split tab"):
                    fname=command[6:].strip(); buffers.append(new_buffer(fname))
                    split_buf_idx=len(buffers)-1; split_open=True; split_active=0; split_orientation="H"
                    message=f"split: {os.path.basename(fname)}"
                elif command=="split close":
                    split_open=False; split_active=0; split_fullscreen=False; message="split closed"
                elif command=="split tab":
                    if split_open:
                        split_open=False; split_fullscreen=False; current_buf=split_buf_idx
                        branch=get_git_branch(buffers[current_buf]["filename"])
                        gutter_markers=get_gutter_markers(buffers[current_buf]["filename"])
                        message="split moved to its own tab"
                    else: message="no split open"
                elif command=="tab split":
                    left_idx=(current_buf-1)%len(buffers)
                    if len(buffers)>1 and left_idx!=current_buf:
                        split_buf_idx=current_buf; current_buf=left_idx
                        split_open=True; split_active=0; split_orientation="H"
                        message=f"merged with left tab"
                    else: message="need at least 2 tabs"
                elif command=="fsplit":
                    start_dir=get_git_root(buf["filename"]) or \
                              (os.path.dirname(os.path.abspath(buf["filename"])) if buf["filename"] else os.getcwd())
                    fp,_=fuzzy_find(stdscr,start_dir)
                    if fp:
                        buffers.append(new_buffer(fp)); split_buf_idx=len(buffers)-1
                        split_open=True; split_active=0; split_orientation="H"
                        message=f"split: {os.path.basename(fp)}"
                    else: message="fsplit cancelled"
                elif command in ("vs","vsplit"):
                    if split_open:
                        split_orientation="V" if split_orientation=="H" else "H"
                        message=f"orientation: {split_orientation}"
                    else:
                        start_dir=get_git_root(buf["filename"]) or \
                                  (os.path.dirname(os.path.abspath(buf["filename"])) if buf["filename"] else os.getcwd())
                        fp,_=fuzzy_find(stdscr,start_dir)
                        if fp:
                            buffers.append(new_buffer(fp)); split_buf_idx=len(buffers)-1
                            split_open=True; split_active=0; split_orientation="V"
                            message=f"vsplit: {os.path.basename(fp)}"
                        else: message="vsplit cancelled"
                elif command.startswith("vs ") or command.startswith("vsplit "):
                    fname=command.split(' ',1)[1].strip(); buffers.append(new_buffer(fname))
                    split_buf_idx=len(buffers)-1; split_open=True; split_active=0; split_orientation="V"
                    message=f"vsplit: {os.path.basename(fname)}"

                # Settings
                elif command.startswith("set tabsize "):
                    try: tab_size[0]=max(1,int(command[12:])); message=f"tab size {tab_size[0]}"
                    except: message="invalid tab size"
                elif command.startswith("set autosave "):
                    try:
                        secs=int(command[13:]); autosave_interval[0]=max(0,secs)*10; autosave_timer=0
                        message=f"autosave {'OFF' if secs==0 else f'every {secs}s'}"
                    except: message="usage: :set autosave N"
                elif command=="set wrap":    word_wrap[0]=True;  message="word wrap ON"
                elif command=="set nowrap":  word_wrap[0]=False; buf["scroll_left"]=0; message="word wrap OFF"
                elif command=="set number":  show_numbers=True;  message="line numbers ON"
                elif command=="set nonumber":show_numbers=False; message="line numbers OFF"
                elif command=="set autocaps":   autocaps_on=True;  message="auto-caps ON"
                elif command=="set noautocaps": autocaps_on=False; message="auto-caps OFF"

                # File ops
                elif command.startswith("rename "):
                    nn=command[7:].strip()
                    if nn and buf["filename"]:
                        np2=os.path.join(os.path.dirname(os.path.abspath(buf["filename"])),nn)
                        try:
                            os.rename(buf["filename"],np2); buf["filename"]=np2
                            branch=get_git_branch(buf["filename"])
                            gutter_markers=get_gutter_markers(buf["filename"]); message=f"renamed to {nn}"
                        except Exception as e: message=f"rename failed: {e}"
                    else: message="usage: :rename newname"
                elif command.startswith("replace "):
                    parts=command[8:].split(' ',1)
                    if len(parts)==2:
                        old,ns2=parts; push_undo(buf); count=0
                        for i,line in enumerate(lines):
                            nl=line.replace(old,ns2)
                            if nl!=line: lines[i]=nl; count+=1
                        buf["modified"]=True; message=f"replaced {count} occurrence{'s' if count!=1 else ''}"
                    else: message="usage: :replace old new"
                elif command.startswith("goto "):
                    try:
                        n=int(command[5:])-1; row=max(0,min(n,len(lines)-1)); col=offset
                        buf["row"]=row; buf["col"]=col
                        buf["scroll_top"]=clamp_scroll(row,scroll_top,primary_h)
                    except: message="invalid line number"
                elif command=="run":
                    if buf["filename"]:
                        panel_open=True; panel.start(buf["filename"],lang)
                        message=f"running {os.path.basename(buf['filename'])}..."
                    else: message="no file to run — save first!"
                elif command=="run close":
                    panel.stop(); panel_open=False; message="panel closed"
                elif command=="h":
                    draw_scrollable(stdscr,HELP_LINES," OVIM HELP ")
                elif command=="undotree":
                    msg=draw_undo_tree(stdscr,buf)
                    lines=buf["lines"]; row=buf["row"]; col=buf["col"]
                    buf["scroll_top"]=clamp_scroll(row,buf["scroll_top"],primary_h)
                    if msg: message=msg

                # Git
                elif command=="gl":
                    git_tree(stdscr,cwd); apply_theme(stdscr); branch=get_git_branch(buf["filename"])
                elif command=="gs":
                    if cwd: out,err=git_run(['status'],cwd=cwd); draw_scrollable(stdscr,(out or err).splitlines()," GIT STATUS ")
                    else: message="not a git repo"
                elif command=="gd":
                    if buf["filename"] and cwd:
                        out,err=git_run(['diff',buf["filename"]],cwd=cwd)
                        if out: draw_scrollable(stdscr,out.splitlines(),f" GIT DIFF — {os.path.basename(buf['filename'])} ")
                        else: message="no changes to show"
                    else: message="no file open"
                elif command=="ga":
                    if buf["filename"] and cwd:
                        out,err=git_run(['add',buf["filename"]],cwd=cwd)
                        gutter_markers=get_gutter_markers(buf["filename"])
                        message=f"staged {os.path.basename(buf['filename'])}" if not err else err
                    else: message="no file open"
                elif command=="gaa":
                    if cwd:
                        out,err=git_run(['add','-A'],cwd=cwd)
                        gutter_markers=get_gutter_markers(buf["filename"])
                        message="staged all files" if not err else err
                    else: message="not a git repo"
                elif command=="gun":
                    if buf["filename"] and cwd:
                        out,err=git_run(['restore','--staged',buf["filename"]],cwd=cwd)
                        gutter_markers=get_gutter_markers(buf["filename"])
                        message=f"unstaged {os.path.basename(buf['filename'])}" if not err else err
                    else: message="no file open"
                elif command=="gc":
                    if cwd:
                        cm=prompt_input(stdscr," Commit message: ")
                        if cm.strip():
                            out,err=git_run(['commit','-m',cm.strip()],cwd=cwd)
                            git_result_popup(stdscr," GIT COMMIT ",out,err)
                            branch=get_git_branch(buf["filename"])
                            gutter_markers=get_gutter_markers(buf["filename"])
                        else: message="commit cancelled"
                    else: message="not a git repo"
                elif command=="gca":
                    if cwd:
                        cm=prompt_input(stdscr," Commit message: ")
                        if cm.strip():
                            git_run(['add','-A'],cwd=cwd)
                            out,err=git_run(['commit','-m',cm.strip()],cwd=cwd)
                            git_result_popup(stdscr," GIT COMMIT ALL ",out,err)
                            branch=get_git_branch(buf["filename"])
                            gutter_markers=get_gutter_markers(buf["filename"])
                        else: message="commit cancelled"
                    else: message="not a git repo"
                elif command=="gp":
                    if cwd:
                        stdscr.addstr(height-1,0," pushing...".ljust(width-1),tcp("statusbar")); stdscr.refresh()
                        out,err=git_run(['push'],cwd=cwd); git_result_popup(stdscr," GIT PUSH ",out,err)
                    else: message="not a git repo"
                elif command=="gpl":
                    if cwd:
                        stdscr.addstr(height-1,0," pulling...".ljust(width-1),tcp("statusbar")); stdscr.refresh()
                        out,err=git_run(['pull'],cwd=cwd); git_result_popup(stdscr," GIT PULL ",out,err)
                        if buf["filename"] and os.path.exists(buf["filename"]):
                            with open(buf["filename"],'r') as f: content=f.read().splitlines()
                            if content: buf["lines"]=content
                            buf["modified"]=False
                        gutter_markers=get_gutter_markers(buf["filename"])
                        branch=get_git_branch(buf["filename"])
                    else: message="not a git repo"
                elif command=="gf":
                    if cwd:
                        stdscr.addstr(height-1,0," fetching...".ljust(width-1),tcp("statusbar")); stdscr.refresh()
                        out,err=git_run(['fetch'],cwd=cwd); git_result_popup(stdscr," GIT FETCH ",out,err)
                    else: message="not a git repo"
                elif command=="gb":
                    if cwd:
                        nb=prompt_input(stdscr," New branch name: ")
                        if nb.strip():
                            out,err=git_run(['checkout','-b',nb.strip()],cwd=cwd)
                            git_result_popup(stdscr," GIT BRANCH ",out,err); branch=get_git_branch(buf["filename"])
                        else: message="cancelled"
                    else: message="not a git repo"
                elif command=="gbd":
                    if cwd:
                        branches=get_git_branches(cwd)
                        if branches:
                            labels=[("* " if cur else "  ")+n for n,cur in branches]+["Cancel"]
                            idx=draw_menu(stdscr," DELETE BRANCH ",labels)
                            if idx is not None and idx<len(branches):
                                bn=branches[idx][0]
                                if draw_menu(stdscr," ARE YOU SURE? ",[f"Delete {bn}","Cancel"])==0:
                                    out,err=git_run(['branch','-d',bn],cwd=cwd)
                                    git_result_popup(stdscr," GIT BRANCH DELETE ",out,err)
                                    branch=get_git_branch(buf["filename"])
                        else: message="no branches found"
                    else: message="not a git repo"
                elif command=="gsw":
                    if cwd:
                        branches=get_git_branches(cwd)
                        if branches:
                            labels=[("* " if cur else "  ")+n for n,cur in branches]+["Cancel"]
                            idx=draw_menu(stdscr," SWITCH BRANCH ",labels)
                            if idx is not None and idx<len(branches):
                                bn=branches[idx][0]; out,err=git_run(['checkout',bn],cwd=cwd)
                                git_result_popup(stdscr," GIT SWITCH ",out,err)
                                branch=get_git_branch(buf["filename"])
                                gutter_markers=get_gutter_markers(buf["filename"])
                                if buf["filename"] and os.path.exists(buf["filename"]):
                                    with open(buf["filename"],'r') as f: content=f.read().splitlines()
                                    if content: buf["lines"]=content
                                    buf["modified"]=False
                        else: message="no branches found"
                    else: message="not a git repo"
                elif command=="gst":
                    if cwd:
                        out,err=git_run(['stash'],cwd=cwd); git_result_popup(stdscr," GIT STASH ",out,err)
                        gutter_markers=get_gutter_markers(buf["filename"])
                        if buf["filename"] and os.path.exists(buf["filename"]):
                            with open(buf["filename"],'r') as f: content=f.read().splitlines()
                            if content: buf["lines"]=content; buf["modified"]=False
                    else: message="not a git repo"
                elif command=="gstp":
                    if cwd:
                        out,err=git_run(['stash','pop'],cwd=cwd); git_result_popup(stdscr," GIT STASH POP ",out,err)
                        gutter_markers=get_gutter_markers(buf["filename"])
                        if buf["filename"] and os.path.exists(buf["filename"]):
                            with open(buf["filename"],'r') as f: content=f.read().splitlines()
                            if content: buf["lines"]=content; buf["modified"]=False
                    else: message="not a git repo"
                elif command=="md":
                    if mark_line is None:
                        mark_line=row; message=f"mark set at line {mark_line+1} — :md again to delete range"
                    else:
                        start=min(mark_line,row); end=max(mark_line,row)
                        push_undo(buf); del lines[start:end+1]
                        if not lines: buf["lines"]=[""]
                        row=max(0,start); col=offset; buf["row"]=row; buf["col"]=col
                        buf["scroll_top"]=clamp_scroll(row,scroll_top,primary_h)
                        buf["modified"]=True; message=f"deleted lines {start+1} to {end+1}"; mark_line=None
                else:
                    message=f"unknown command: {command}"

                mode="normal"; command=""
            elif key in (curses.KEY_BACKSPACE,127,8): command=command[:-1]
            elif 32<=key<=126: command+=chr(key)

    panel.stop()

curses.wrapper(main)