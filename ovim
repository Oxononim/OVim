def draw_scrollable(stdscr,lines,title,extra_hint=""):
    scroll=0
    while True:
        stdscr.erase(); height,width=stdscr.getmaxyx()
        stdscr.addstr(0,0,title.center(width)[:width-1],tcp("statusbar")|curses.A_BOLD)
        visible=lines[scroll:scroll+height-2]
        for i,line in enumerate(visible):
            if line.startswith('+') and not line.startswith('+++'): color=tcp("diff_add")
            elif line.startswith('-') and not line.startswith('---'): color=tcp("diff_del")
            elif line.startswith('@@'): color=tcp("diff_hdr")
            elif any(line.startswith(k) for k in ('commit','Author','Date','On branch','Your branch')): color=tcp("git_hash")
            elif line.startswith('Changes') or line.startswith('Untracked') or line.startswith('nothing'): color=tcp("git_ref")
            else: color=tcp("normal")
            try: stdscr.addstr(i+1,0,line[:width-1],color)
            except: pass
        hint=f" [↑↓/PgUp/PgDn] {extra_hint}[q] close  [{scroll+1}/{len(lines)}] "
        stdscr.addstr(height-1,0,hint.ljust(width-1)[:width-1],tcp("statusbar"))
        stdscr.refresh()
        key=stdscr.getch()
        if key in (ord('q'),ord('Q'),27): return False
        elif key in (curses.KEY_ENTER,10,13): return True
        elif key==curses.KEY_UP and scroll>0: scroll-=1
        elif key==curses.KEY_DOWN and scroll<max(0,len(lines)-(height-2)): scroll+=1
        elif key==curses.KEY_PPAGE: scroll=max(0,scroll-(height-2))
        elif key==curses.KEY_NPAGE: scroll=min(max(0,len(lines)-(height-2)),scroll+(height-2))

def git_result_popup(stdscr,title,out,err):
    lines=[]
    if out: lines+=out.splitlines()
    if err: lines+=err.splitlines()
    if not lines: lines=["done!"]
    draw_scrollable(stdscr,lines,title)

def draw_menu(stdscr,title,options):
    height,width=stdscr.getmaxyx()
    if not options: return None
    menu_h=min(len(options)+4,height-2)
    menu_w=min(max(len(title),max(len(o) for o in options))+6,width-2)
    y=(height-menu_h)//2; x=(width-menu_w)//2
    selected=0; visible_count=menu_h-4; scroll=0
    while True:
        for i in range(menu_h):
            try: stdscr.addstr(y+i,x," "*menu_w,tcp("statusbar"))
            except: pass
        try: stdscr.addstr(y+1,x+(menu_w-len(title))//2,title[:menu_w-2],tcp("statusbar")|curses.A_BOLD)
        except: pass
        for i in range(visible_count):
            oi=scroll+i
            if oi>=len(options): break
            attr=tcp("statusbar")|curses.A_REVERSE if oi==selected else tcp("statusbar")
            try: stdscr.addstr(y+2+i,x+2,options[oi][:menu_w-4].ljust(menu_w-4),attr)
            except: pass
        stdscr.refresh()
        key=stdscr.getch()
        if key==curses.KEY_UP and selected>0:
            selected-=1
            if selected<scroll: scroll=selected
        elif key==curses.KEY_DOWN and selected<len(options)-1:
            selected+=1
            if selected>=scroll+visible_count: scroll=selected-visible_count+1
        elif key in (curses.KEY_ENTER,10,13): return selected
        elif key==27: return None

def prompt_input(stdscr,prompt):
    height,width=stdscr.getmaxyx()
    stdscr.timeout(-1); curses.curs_set(1)
    stdscr.addstr(height-1,0,prompt.ljust(width-1),tcp("statusbar"))
    stdscr.refresh(); curses.echo(); stdscr.move(height-1,len(prompt))
    try: val=stdscr.getstr(height-1,len(prompt),80).decode()
    except: val=""
    curses.noecho(); stdscr.timeout(100); return val

# ─── 256-color picker ─────────────────────────────────────────────────────────
# Display order: standard 0-7, bright 8-15, then 6x6x6 cube 16-231,
# then grayscale 232-255.  Each section is visually separated.
# "D" (default / -1) is shown as a special top-left cell.

def init_picker_pairs():
    n=min(256,curses.COLORS)
    for i in range(n):
        try:
            # Light fg on dark colors, dark fg on light colors
            if i==0:                    fg=7
            elif i in (7,15):           fg=0
            elif 16<=i<=231:
                idx=i-16; b=idx%6; idx//=6; g=idx%6; r=idx//6
                fg=0 if (r+g+b)>9 else 7
            elif 232<=i<=255:           fg=0 if i>244 else 7
            else:                       fg=7
            curses.init_pair(PICKER_PAIR_BASE+i, fg, i)
        except: break

def draw_color_picker_256(stdscr, title, current=-1):
    """
    Organised 256-color picker.
    Row 0 : D  + colors  0-7   (standard 8)
    Row 1 :      colors  8-15  (bright 8)
    gap
    Rows 2-7 :   colors 16-231 (6x6x6 cube, one row per R-value, 36 cols each)
    gap
    Row 8 :      colors 232-243 (dark grays)
    Row 9 :      colors 244-255 (light grays)
    """
    n = min(256, curses.COLORS)

    # Build grid: list of rows, None = visual gap
    grid = [
        [-1] + list(range(8)),       # D + standard
        list(range(8, 16)),          # bright
        None,                        # gap
    ]
    for r in range(6):
        # one row per red-channel value; g and b vary
        grid.append([16 + r*36 + g*6 + b for g in range(6) for b in range(6)])
    grid.append(None)                # gap
    grid.append(list(range(232, 244)))   # dark grays
    grid.append(list(range(244, 256)))   # light grays

    real_rows = [row for row in grid if row is not None]

    def find_pos(cval):
        for ri, row in enumerate(real_rows):
            if cval in row:
                return ri, row.index(cval)
        return 0, 0

    if current == -1:   sel_r, sel_c = 0, 0
    elif 0 <= current < n: sel_r, sel_c = find_pos(current)
    else:               sel_r, sel_c = 0, 0

    CELL = 2   # chars per swatch — cube has 36 cols so 2 keeps it ≤ 72 wide

    while True:
        stdscr.erase(); H, W = stdscr.getmaxyx()
        try:
            stdscr.addstr(0, 0, title.center(W)[:W-1], tcp("statusbar") | curses.A_BOLD)
        except: pass

        max_cols = max(len(r) for r in real_rows)   # 36 for cube rows
        GX = max(1, (W - max_cols * CELL) // 2)
        GY = 2

        # Draw grid and record each real-row's screen y
        row_sy = []   # screen-y for real_rows[i]
        sy = GY
        ri = 0
        for row in grid:
            if row is None:
                sy += 1
                continue
            row_sy.append(sy)
            for ci, cval in enumerate(row):
                sx = GX + ci * CELL
                if sy >= H - 4 or sx + CELL > W:
                    continue
                is_sel = (ri == sel_r and ci == sel_c)
                try:
                    if cval == -1:
                        label = ("D " if CELL == 2 else " D ")[:CELL]
                        a = tcp("statusbar") | (curses.A_REVERSE if is_sel else 0)
                        stdscr.addstr(sy, sx, label, a)
                    else:
                        a = curses.color_pair(PICKER_PAIR_BASE + cval)
                        if is_sel: a |= curses.A_REVERSE
                        stdscr.addstr(sy, sx, " " * CELL, a)
                except: pass
            ri += 1
            sy += 1

        # Section labels (right of grid)
        label_x = GX + max_cols * CELL + 2
        labels_at = {
            row_sy[0]: "base",
            row_sy[1]: "bright",
            row_sy[2]: "cube",
            row_sy[8]: "gray",
        }
        for label_y, lbl in labels_at.items():
            try: stdscr.addstr(label_y, label_x, lbl, tcp("comment"))
            except: pass

        # Info bar
        sel_val = real_rows[sel_r][sel_c]
        try:
            if sel_val == -1:
                stdscr.addstr(H-3, GX, " D = terminal default color ", tcp("statusbar"))
            else:
                sa = curses.color_pair(PICKER_PAIR_BASE + sel_val)
                stdscr.addstr(H-3, GX,      f" #{sel_val:03d} ",        sa)
                stdscr.addstr(H-3, GX + 7,  "  sample text  ",          sa | curses.A_BOLD)
                stdscr.addstr(H-3, GX + 23, "  italic  ",               sa | curses.A_ITALIC)
        except: pass

        hint = " [←→↑↓] move  [PgUp/Dn] jump  [Enter] select  [D] default  [Esc] cancel "
        try: stdscr.addstr(H-1, 0, hint.ljust(W-1)[:W-1], tcp("statusbar"))
        except: pass

        # Cursor
        if sel_r < len(row_sy):
            try: stdscr.move(row_sy[sel_r], GX + sel_c * CELL)
            except: pass
        stdscr.refresh()

        key = stdscr.getch()
        if   key == 27:                         return None
        elif key in (curses.KEY_ENTER, 10, 13): return sel_val
        elif key in (ord('d'), ord('D')):       return -1
        elif key == curses.KEY_LEFT:
            if sel_c > 0: sel_c -= 1
        elif key == curses.KEY_RIGHT:
            if sel_c < len(real_rows[sel_r]) - 1: sel_c += 1
        elif key == curses.KEY_UP:
            if sel_r > 0:
                sel_r -= 1
                sel_c = min(sel_c, len(real_rows[sel_r]) - 1)
        elif key == curses.KEY_DOWN:
            if sel_r < len(real_rows) - 1:
                sel_r += 1
                sel_c = min(sel_c, len(real_rows[sel_r]) - 1)
        elif key == curses.KEY_PPAGE:
            sel_r = max(0, sel_r - 3)
            sel_c = min(sel_c, len(real_rows[sel_r]) - 1)
        elif key == curses.KEY_NPAGE:
            sel_r = min(len(real_rows) - 1, sel_r + 3)
            sel_c = min(sel_c, len(real_rows[sel_r]) - 1)

def draw_attrs_picker(stdscr,title,current_attrs=0):
    options=[("Bold",curses.A_BOLD),("Italic",curses.A_ITALIC),("Dim",curses.A_DIM),
             ("Underline",curses.A_UNDERLINE),("Reverse",curses.A_REVERSE)]
