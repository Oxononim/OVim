def apply_theme(stdscr=None):
    for key,(pair,fg,bg,attrs) in theme.items():
        try: curses.init_pair(pair,fg,bg)
        except: pass
    if stdscr: stdscr.bkgd(' ',tcp("background"))

def save_theme_to_file(name,tab_size,word_wrap):
    os.makedirs(THEME_DIR,exist_ok=True)
    data={"tab_size":tab_size[0],"word_wrap":word_wrap[0]}
    for key,(pair,fg,bg,attrs) in theme.items():
        data[key]={"pair":pair,"fg":fg,"bg":bg,"attrs":attrs}
    path=os.path.join(THEME_DIR,f"{name}.json")
    with open(path,'w') as f: json.dump(data,f,indent=2)
    return path

def load_theme_from_file(name,tab_size,word_wrap):
    path=os.path.join(THEME_DIR,f"{name}.json")
    if not os.path.exists(path): return False
    with open(path,'r') as f: data=json.load(f)
    if "tab_size" in data: tab_size[0]=data["tab_size"]
    if "word_wrap" in data: word_wrap[0]=data["word_wrap"]
    def pc(v):
        if isinstance(v,int): return v
        return {"Default":-1,"Black":0,"Red":1,"Green":2,"Yellow":3,"Blue":4,"Magenta":5,"Cyan":6,"White":7}.get(v,-1)
    for key,val in data.items():
        if key in theme and isinstance(val,dict):
            theme[key]=(val.get("pair",theme[key][0]),pc(val.get("fg",-1)),pc(val.get("bg",-1)),val.get("attrs",0))
    return True

def list_saved_themes():
    if not os.path.exists(THEME_DIR): return []
    return [f[:-5] for f in os.listdir(THEME_DIR) if f.endswith(".json")]

