# ─── Editor helpers ───────────────────────────────────────────────────────────

def detect_language(filename,lines):
    if filename:
        ext=os.path.splitext(filename)[1].lstrip('.')
        if ext in custom_langs: return f"custom_{ext}"
        if ext=="py":   return "python"
        if ext=="sh":   return "bash"
        if ext=="json": return "json"
    if lines and lines[0].startswith("#!"):
        shebang=lines[0].lower()
        if "python" in shebang: return "python"
        if "bash" in shebang or "sh" in shebang: return "bash"
    return None

def is_plain_text(filename,lang):
    if lang: return False
    if not filename: return True
    return os.path.splitext(filename)[1] in ('.txt','.md','.rst','')

def highlight_line(line,lang,search_pattern=None):
    spans=[]; patterns=[]
    if lang and lang in HIGHLIGHTS: patterns=HIGHLIGHTS[lang]
    elif lang and lang.startswith("custom_"):
        ext=lang[7:]
        if ext in custom_langs:
            cl=custom_langs[ext]
            cm={"keywords":COLOR_KEYWORD,"strings":COLOR_STRING,"comments":COLOR_COMMENT,
                "numbers":COLOR_NUMBER,"functions":COLOR_FUNCTION}
            for field,color in cm.items():
                pat=cl.get(field,"")
                if pat: patterns.append((color,pat))
    for color,pattern in patterns:
        try:
            for m in re.finditer(pattern,line): spans.append((m.start(),m.end(),color))
        except: pass
    if search_pattern:
        try:
            for m in re.finditer(search_pattern,line): spans.append((m.start(),m.end(),COLOR_SEARCH))
        except: pass
    if not spans: return [(line,COLOR_NORMAL)]
    spans.sort(key=lambda s:s[0]); merged=[]
    for span in spans:
        if merged and span[0]<merged[-1][1]:
            if span[2]==COLOR_SEARCH:
                last=merged[-1]
                if last[0]<span[0]: merged[-1]=(last[0],span[0],last[2])
                else: merged.pop()
                merged.append(span)
            continue
        merged.append(span)
    chunks=[]; pos=0
    for start,end,color in merged:
        if pos<start: chunks.append((line[pos:start],COLOR_NORMAL))
        chunks.append((line[start:end],color)); pos=end
    if pos<len(line): chunks.append((line[pos:],COLOR_NORMAL))
    return chunks

def get_search_matches(lines,pattern):
    matches=[]
    if not pattern: return matches
    try:
        for i,line in enumerate(lines):
            for m in re.finditer(pattern,line): matches.append((i,m.start()))
    except: pass
    return matches

def get_auto_indent(line,lang):
    indent=len(line)-len(line.lstrip()); ci=line[:indent]; stripped=line.rstrip()
    if lang=="python" and stripped.endswith(":"): return ci+"    "
    if lang=="bash"   and stripped.endswith(("then","do","{","()")): return ci+"    "
    if lang=="json"   and stripped.endswith(("{","[")): return ci+"  "
    return ci

def find_matching_indent(lines,row,closing_kw,lang):
    if lang!="bash" or closing_kw not in BASH_OPENERS: return None
    openers,closers=BASH_OPENERS[closing_kw]; depth=0
    for r in range(row-1,-1,-1):
        s=lines[r].strip().split()
        if not s: continue
        first=s[0]
        if first in closers and r<row: depth+=1
        elif first in openers:
            if depth==0: return len(lines[r])-len(lines[r].lstrip())
            depth-=1
    return None

def should_autocap(lines,row,col,offset):
    tc=col-offset
    if tc==0:
        if row==0: return True
        for r in range(row-1,-1,-1):
            s=lines[r].rstrip()
            if s: return s[-1] in '.!?'
        return True
    line=lines[row]; i=tc-1
    while i>=0 and line[i]==' ': i-=1
    if i<0:
        if row>0:
            prev=lines[row-1].rstrip()
            return bool(prev) and prev[-1] in '.!?'
        return False
    return line[i] in '.!?' and (tc-1-i)>=1

def copy_to_clipboard(text):
    try: subprocess.run(['wl-copy'],input=text.encode(),check=True)
    except: pass

def paste_from_clipboard():
    try: return subprocess.run(['wl-paste','--no-newline'],capture_output=True).stdout.decode()
    except: return ""

def save(lines,filename):
    if filename:
        with open(filename,'w') as f: f.write('\n'.join(lines))
        return True
    return False

def num_offset(total_lines,show_numbers):
    return len(str(total_lines))+1 if show_numbers else 0

def clamp_scroll(row,scroll_top,height):
    if row<scroll_top: scroll_top=row
    elif row>=scroll_top+height-1: scroll_top=row-height+2
    return max(0,scroll_top)

def wrap_line(line,pane_width,offset):
    tw=pane_width-offset
    if tw<=0 or len(line)<=tw: return [line]
    chunks=[]
    while line: chunks.append(line[:tw]); line=line[tw:]
    return chunks

def word_forward(lines,row,col,offset):
    line=lines[row]; tc=col-offset
    while tc<len(line) and (line[tc].isalnum() or line[tc]=='_'): tc+=1
    while tc<len(line) and not (line[tc].isalnum() or line[tc]=='_'): tc+=1
    if tc>=len(line) and row<len(lines)-1: return row+1,offset
    return row,tc+offset

def word_back(lines,row,col,offset):
    line=lines[row]; tc=col-offset
    if tc<=0 and row>0: return row-1,len(lines[row-1])+offset
    tc-=1
    while tc>0 and not (line[tc].isalnum() or line[tc]=='_'): tc-=1
    while tc>0 and (line[tc-1].isalnum() or line[tc-1]=='_'): tc-=1
    return row,max(0,tc)+offset

def char_in_selection(li,ci,vis_start,vis_end,offset):
    if vis_start is None or vis_end is None: return False
    r1,c1=vis_start[0],vis_start[1]-offset; r2,c2=vis_end[0],vis_end[1]-offset
    if r1>r2 or (r1==r2 and c1>c2): r1,c1,r2,c2=r2,c2,r1,c1
    c1=max(0,c1); c2=max(0,c2)
    if li<r1 or li>r2: return False
    if r1==r2: return c1<=ci<c2
    if li==r1: return ci>=c1
    if li==r2: return ci<c2
    return True

def ww_move_j(lines,row,col,offset,pane_width,scroll_top,height,pvc):
    tw=max(1,pane_width-offset); tc=col-offset; ci=tc//tw
    line=lines[row]; nk=max(1,-(-max(1,len(line))//tw)) if line else 1
    if ci<nk-1:
        ntc=min((ci+1)*tw+pvc,len(line)); return row,ntc+offset,scroll_top
    elif row<len(lines)-1:
        row+=1; ntc=min(pvc,len(lines[row]))
        st=clamp_scroll(row,scroll_top,height); return row,ntc+offset,st
    return row,col,scroll_top

def ww_move_k(lines,row,col,offset,pane_width,scroll_top,height,pvc):
    tw=max(1,pane_width-offset); tc=col-offset; ci=tc//tw
    if ci>0:
        ntc=min((ci-1)*tw+pvc,len(lines[row])); return row,ntc+offset,scroll_top
    elif row>0:
        row-=1; line=lines[row]; nk=max(1,-(-max(1,len(line))//tw)) if line else 1
        last_ci=nk-1; ntc=min(last_ci*tw+pvc,len(line))
        st=clamp_scroll(row,scroll_top,height); return row,ntc+offset,st
    return row,col,scroll_top

