def new_buffer(filename=None):
    lines = [""]
    if filename and os.path.exists(filename):
        with open(filename, 'r') as f:
            content = f.read().splitlines()
        if content:
            lines = content
    return {
        "lines":       lines,
        "filename":    filename,
        "row":         0,
        "col":         0,
        "scroll_top":  0,
        "scroll_left": 0,
        "modified":    False,
        "undo_stack":  [],
        "redo_stack":  [],
    }

def apply_theme(stdscr=None):
    for key, (pair, fg, bg) in theme.items():
        curses.init_pair(pair, fg, bg)
    if stdscr:
        stdscr.bkgd(' ', curses.color_pair(COLOR_BACKGROUND))

def save_theme_to_file(name, tab_size, word_wrap):
    os.makedirs(THEME_DIR, exist_ok=True)
    data = {"tab_size": tab_size[0], "word_wrap": word_wrap[0]}
    for key, (pair, fg, bg) in theme.items():
        data[key] = {"pair": pair, "fg": COLOR_ID_TO_NAME.get(fg, "Default"),
                     "bg": COLOR_ID_TO_NAME.get(bg, "Default")}
    path = os.path.join(THEME_DIR, f"{name}.json")
    with open(path, 'w') as f:
        json.dump(data, f, indent=2)
    return path

def load_theme_from_file(name, tab_size, word_wrap):
    path = os.path.join(THEME_DIR, f"{name}.json")
    if not os.path.exists(path):
        return False
    with open(path, 'r') as f:
        data = json.load(f)
    name_to_id = {k: v for k, v in COLOR_NAMES}
    if "tab_size" in data:
        tab_size[0] = data["tab_size"]
    if "word_wrap" in data:
        word_wrap[0] = data["word_wrap"]
    for key, val in data.items():
        if key in theme and isinstance(val, dict):
            theme[key] = (val["pair"], name_to_id.get(val["fg"], -1),
                          name_to_id.get(val["bg"], -1))
    return True

def list_saved_themes():
    if not os.path.exists(THEME_DIR):
        return []
    return [f[:-5] for f in os.listdir(THEME_DIR) if f.endswith(".json")]

def highlight_line(line, lang, search_pattern=None):
    spans = []
    if lang and lang in HIGHLIGHTS:
        for color, pattern in HIGHLIGHTS[lang]:
            for m in re.finditer(pattern, line):
                spans.append((m.start(), m.end(), color))
    if search_pattern:
        try:
            for m in re.finditer(search_pattern, line):
                spans.append((m.start(), m.end(), COLOR_SEARCH))
        except re.error:
            pass
    if not spans:
        return [(line, COLOR_NORMAL)]
    spans.sort(key=lambda s: s[0])
    merged = []
    for span in spans:
        if merged and span[0] < merged[-1][1]:
            if span[2] == COLOR_SEARCH:
                last = merged[-1]
                if last[0] < span[0]:
                    merged[-1] = (last[0], span[0], last[2])
                else:
                    merged.pop()
                merged.append(span)
            continue
        merged.append(span)
    chunks = []
    pos = 0
    for start, end, color in merged:
        if pos < start:
            chunks.append((line[pos:start], COLOR_NORMAL))
        chunks.append((line[start:end], color))
        pos = end
    if pos < len(line):
        chunks.append((line[pos:], COLOR_NORMAL))
    return chunks

def get_search_matches(lines, pattern):
    matches = []
    if not pattern:
        return matches
    try:
        for i, line in enumerate(lines):
            for m in re.finditer(pattern, line):
                matches.append((i, m.start()))
    except re.error:
        pass
    return matches

def draw_menu(stdscr, title, options):
    height, width = stdscr.getmaxyx()
    menu_h = min(len(options) + 4, height - 2)
    menu_w = min(max(len(title), max(len(o) for o in options)) + 6, width - 2)
    y = (height - menu_h) // 2
    x = (width  - menu_w) // 2
    selected     = 0
    visible_count = menu_h - 4
    scroll       = 0
    while True:
        stdscr.attron(curses.color_pair(COLOR_STATUSBAR))
        for i in range(menu_h):
            try:
                stdscr.addstr(y + i, x, " " * menu_w)
            except:
                pass
        stdscr.attroff(curses.color_pair(COLOR_STATUSBAR))
        try:
            stdscr.addstr(y + 1, x + (menu_w - len(title)) // 2, title[:menu_w-2],
                          curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD)
        except:
            pass
        for i in range(visible_count):
            oi = scroll + i
            if oi >= len(options):
                break
            attr = curses.color_pair(COLOR_STATUSBAR) | curses.A_REVERSE if oi == selected \
                   else curses.color_pair(COLOR_STATUSBAR)
            try:
                stdscr.addstr(y + 2 + i, x + 2, options[oi][:menu_w-4].ljust(menu_w - 4), attr)
            except:
                pass
        stdscr.refresh()
        key = stdscr.getch()
        if key == curses.KEY_UP and selected > 0:
            selected -= 1
            if selected < scroll:
                scroll = selected
        elif key == curses.KEY_DOWN and selected < len(options) - 1:
            selected += 1
            if selected >= scroll + visible_count:
                scroll = selected - visible_count + 1
        elif key in (curses.KEY_ENTER, 10, 13):
            return selected
        elif key == 27:
            return None

def draw_color_picker(stdscr, title):
    idx = draw_menu(stdscr, title, [name for name, _ in COLOR_NAMES])
    if idx is None:
        return None
    return COLOR_NAMES[idx][1]

def prompt_input(stdscr, prompt):
    height, width = stdscr.getmaxyx()
    stdscr.timeout(-1)
    curses.curs_set(1)
    stdscr.addstr(height-1, 0, prompt.ljust(width-1), curses.color_pair(COLOR_STATUSBAR))
    stdscr.refresh()
    curses.echo()
    stdscr.move(height-1, len(prompt))
    try:
        val = stdscr.getstr(height-1, len(prompt), 80).decode()
    except:
        val = ""
    curses.noecho()
    stdscr.timeout(100)
    return val

