def draw_preview(stdscr, y, x, h, w, preview_mode, word_wrap):
    try:
        for i in range(h):
            stdscr.addstr(y + i, x, " " * w, curses.color_pair(COLOR_NORMAL))

        if preview_mode == "syntax":
            for i, line in enumerate(PREVIEW_SYNTAX):
                if i >= h:
                    break
                px = x
                for text, color in highlight_line(line, "python"):
                    if px < x + w - 1:
                        stdscr.addstr(y + i, px, text[:x+w-1-px], curses.color_pair(color))
                        px += len(text)

        elif preview_mode == "gutter_ui":
            rows = [
                ("+ ", "new line added here",  COLOR_GUTTER_ADD),
                ("~ ", "modified line here",   COLOR_GUTTER_MOD),
                ("- ", "line deleted below",   COLOR_GUTTER_DEL),
                ("  ", "unchanged line",       COLOR_LINENR),
                ("  ", "unchanged line",       COLOR_LINENR),
            ]
