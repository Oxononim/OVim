        bottom=" [Enter] Edit  [S] Save  [L] Load  [D] Delete  [Q] Done"
        if message: bottom=f" {message}"
        stdscr.addstr(height-2,0,bottom.ljust(width-1),tcp("statusbar"))
        stdscr.refresh()
        key=stdscr.getch(); message=""
        if key==curses.KEY_UP and selected>0: selected-=1
        elif key==curses.KEY_DOWN and selected<len(ELEMENTS)-1: selected+=1
        elif key in (curses.KEY_ENTER,10,13):
            _,elem_key=ELEMENTS[selected]
            if   elem_key=="__sep__": pass
            elif elem_key=="__wrap__": word_wrap[0]=not word_wrap[0]; message=f"word wrap {'ON' if word_wrap[0] else 'OFF'}"
            elif elem_key=="__tabsize__":
                val=prompt_input(stdscr," Tab size: ")
