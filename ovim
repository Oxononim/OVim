            else:
                pair,fg,bg,attrs=theme[key]
                as_="".join(c for c,f in [("B",curses.A_BOLD),("I",curses.A_ITALIC),("D",curses.A_DIM),("U",curses.A_UNDERLINE)] if attrs&f)
                entry=f" {label}: fg={fg} bg={bg}{' ['+as_+']' if as_ else ''}"
                attr=(tcp("statusbar")|curses.A_REVERSE) if ei==selected else (curses.color_pair(pair)|attrs)
            try: stdscr.addstr(2+i,preview_w+1,entry.ljust(side_w),attr)
            except: pass
        if len(ELEMENTS)>list_h:
