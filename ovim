# ─── Git helpers ──────────────────────────────────────────────────────────────

def git_run(args, cwd):
    try:
        r = subprocess.run(['git'] + args, capture_output=True, cwd=cwd)
        return r.stdout.decode(errors='replace').strip(), r.stderr.decode(errors='replace').strip()
    except:
        return "", "git not found"

def get_git_root(filename):
    if not filename:
        return None
    try:
        r = subprocess.run(
            ['git', 'rev-parse', '--show-toplevel'],
            capture_output=True,
            cwd=os.path.dirname(os.path.abspath(filename))
        )
        out = r.stdout.decode().strip()
        return out if out else None
    except:
        return None

def get_git_branch(filename):
    if not filename:
        return None
    try:
        cwd = os.path.dirname(os.path.abspath(filename))
        result = subprocess.run(['git', 'branch', '--show-current'], capture_output=True, cwd=cwd)
        branch = result.stdout.decode().strip()
        return branch if branch else None
    except:
        return None

def get_git_log(cwd):
    fmt = '%x1f'.join(['%H', '%D', '%s', '%an', '%ar'])
    raw, _ = git_run(['log', '--graph', '--all', '--format=%x00' + fmt], cwd=cwd)
    entries = []
    for line in raw.splitlines():
        if '\x00' in line:
            graph_part, rest = line.split('\x00', 1)
            fields = rest.split('\x1f')
            if len(fields) >= 5:
                h, refs, msg, author, date = fields[:5]
                entries.append({
                    'graph': graph_part, 'hash': h[:7], 'fullhash': h,
                    'refs': refs, 'msg': msg, 'author': author, 'date': date,
                })
            else:
                entries.append({'graph': graph_part, 'hash': '', 'fullhash': '', 'refs': '', 'msg': '', 'author': '', 'date': ''})
        else:
            entries.append({'graph': line, 'hash': '', 'fullhash': '', 'refs': '', 'msg': '', 'author': '', 'date': ''})
    return entries

def get_commit_diff(cwd, fullhash):
    out, _ = git_run(['show', '--stat', fullhash], cwd=cwd)
    return out

def get_commit_full_diff(cwd, fullhash):
    out, _ = git_run(['show', fullhash], cwd=cwd)
    return out

def get_git_branches(cwd):
    raw, _ = git_run(['branch', '-a'], cwd=cwd)
    branches = []
    for line in raw.splitlines():
        line = line.strip()
        is_current = line.startswith('*')
        name = line.lstrip('* ').strip()
        if '->' not in name:
            branches.append((name, is_current))
    return branches

def git_checkout(cwd, branch):
    try:
        r = subprocess.run(['git', 'checkout', branch], capture_output=True, cwd=cwd)
        return (r.stdout + r.stderr).decode().strip()
    except Exception as e:
        return str(e)

def get_gutter_markers(filename):
    """Returns dict of line_number -> '+' | '~' | '-'"""
    markers = {}
    if not filename or not os.path.exists(filename):
        return markers
    try:
        cwd = os.path.dirname(os.path.abspath(filename))
        r = subprocess.run(
            ['git', 'diff', '--unified=0', filename],
            capture_output=True, cwd=cwd
        )
        output = r.stdout.decode(errors='replace')
        current_line = 0
        for line in output.splitlines():
            m = re.match(r'@@ -\d+(?:,\d+)? \+(\d+)(?:,(\d+))? @@', line)
            if m:
                current_line = int(m.group(1))
                count = int(m.group(2)) if m.group(2) is not None else 1
                if count == 0:
                    # deletion — mark line before
                    markers[max(1, current_line)] = '-'
                continue
            if line.startswith('+') and not line.startswith('+++'):
                markers[current_line] = '+'
                current_line += 1
            elif line.startswith('-') and not line.startswith('---'):
                # modification or deletion
                if current_line in markers and markers[current_line] == '+':
                    markers[current_line] = '~'
                else:
                    markers[current_line] = '~'
            elif not line.startswith('\\'):
                if not line.startswith('-') and not line.startswith('+'):
                    current_line += 1
    except:
        pass
    return markers

# ─── Git UI helpers ───────────────────────────────────────────────────────────

def draw_scrollable(stdscr, lines, title, extra_hint=""):
    scroll = 0
    while True:
        stdscr.clear()
        height, width = stdscr.getmaxyx()
        stdscr.addstr(0, 0, title.center(width)[:width-1], curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD)
        visible = lines[scroll:scroll + height - 2]
        for i, line in enumerate(visible):
            if line.startswith('+') and not line.startswith('+++'):
                color = curses.color_pair(COLOR_DIFF_ADD)
            elif line.startswith('-') and not line.startswith('---'):
                color = curses.color_pair(COLOR_DIFF_DEL)
            elif line.startswith('@@'):
                color = curses.color_pair(COLOR_DIFF_HDR)
            elif any(line.startswith(k) for k in ('commit', 'Author', 'Date', 'On branch', 'Your branch')):
                color = curses.color_pair(COLOR_GIT_HASH)
            elif line.startswith('Changes') or line.startswith('Untracked') or line.startswith('nothing'):
                color = curses.color_pair(COLOR_GIT_REF)
            else:
                color = curses.color_pair(COLOR_NORMAL)
            try:
                stdscr.addstr(i + 1, 0, line[:width-1], color)
            except:
                pass
        hint = f" [↑↓/PgUp/PgDn] scroll  {extra_hint}[q] close  [{scroll+1}/{len(lines)}] "
        stdscr.addstr(height-1, 0, hint.ljust(width-1)[:width-1], curses.color_pair(COLOR_STATUSBAR))
        stdscr.refresh()
        key = stdscr.getch()
        if key in (ord('q'), ord('Q'), 27):
            return False
        elif key in (curses.KEY_ENTER, 10, 13):
            return True
        elif key == curses.KEY_UP and scroll > 0:
            scroll -= 1
        elif key == curses.KEY_DOWN and scroll < max(0, len(lines) - (height - 2)):
            scroll += 1
        elif key == curses.KEY_PPAGE:
            scroll = max(0, scroll - (height - 2))
        elif key == curses.KEY_NPAGE:
            scroll = min(max(0, len(lines) - (height - 2)), scroll + (height - 2))

def git_result_popup(stdscr, title, out, err):
    lines = []
    if out:
        lines += out.splitlines()
    if err:
        lines += err.splitlines()
    if not lines:
        lines = ["done!"]
    draw_scrollable(stdscr, lines, title)

# ─── Git Tree ─────────────────────────────────────────────────────────────────

def draw_graph_line(stdscr, y, graph, hash_, refs, msg, author, date, selected, width):
    if selected:
        stdscr.attron(curses.A_REVERSE)
    x = 0
    for ch in graph:
        if x >= width - 1:
            break
        attr = curses.color_pair(COLOR_GIT_GRAPH) if ch in '|/\\*' else curses.color_pair(COLOR_NORMAL)
        if selected:
            attr |= curses.A_REVERSE
        try:
            stdscr.addch(y, x, ch, attr)
        except:
            pass
        x += 1
    if hash_:
        h_attr = curses.color_pair(COLOR_GIT_HASH) | (curses.A_REVERSE if selected else 0)
        try:
            stdscr.addstr(y, x, f" {hash_}"[:width-x-1], h_attr)
        except:
            pass
        x += len(f" {hash_}")
        if refs:
            for ref in [r.strip() for r in refs.split(',') if r.strip()]:
                if x >= width - 2:
                    break
                r_attr = curses.color_pair(COLOR_GIT_REF) | (curses.A_REVERSE if selected else 0)
                ref_str = f" ({ref})"
                try:
                    stdscr.addstr(y, x, ref_str[:width-x-1], r_attr)
                except:
                    pass
                x += len(ref_str)
        if msg and x < width - 1:
            m_attr = curses.color_pair(COLOR_NORMAL) | (curses.A_REVERSE if selected else 0)
            try:
                stdscr.addstr(y, x, f" {msg}"[:width-x-1], m_attr)
            except:
                pass
            x += len(f" {msg}")
        if author and date:
            info = f" {author}, {date} "
            info_x = width - len(info) - 1
            if info_x > x:
                i_attr = curses.color_pair(COLOR_COMMENT) | (curses.A_REVERSE if selected else 0)
                try:
                    stdscr.addstr(y, info_x, info[:width-info_x-1], i_attr)
                except:
                    pass
    if selected:
        stdscr.attroff(curses.A_REVERSE)

def git_tree(stdscr, cwd):
    if not cwd:
        draw_menu(stdscr, " GIT TREE ", ["Not a git repo!", "OK"])
        return
    stdscr.clear()
    height, width = stdscr.getmaxyx()
    msg = " loading git log... "
    stdscr.addstr(height//2, (width-len(msg))//2, msg, curses.color_pair(COLOR_STATUSBAR))
    stdscr.refresh()
    entries = get_git_log(cwd)
    if not entries:
        draw_menu(stdscr, " GIT TREE ", ["No commits found!", "OK"])
        return
    commit_indices = [i for i, e in enumerate(entries) if e['hash']]
    if not commit_indices:
        draw_menu(stdscr, " GIT TREE ", ["No commits found!", "OK"])
        return
    selected_commit = 0
    scroll = 0
    while True:
        stdscr.clear()
        height, width = stdscr.getmaxyx()
        text_height = height - 2
        stdscr.addstr(0, 0, " GIT TREE ".center(width)[:width-1], curses.color_pair(COLOR_STATUSBAR) | curses.A_BOLD)
        for i in range(text_height):
            ei = scroll + i
            if ei >= len(entries):
                break
            e = entries[ei]
            is_sel = ei in commit_indices and commit_indices.index(ei) == selected_commit
            draw_graph_line(stdscr, i+1, e['graph'], e['hash'], e['refs'], e['msg'], e['author'], e['date'], is_sel, width)
        sel = entries[commit_indices[selected_commit]]
        bottom = f" [{sel['hash']}] {sel['msg'][:35]}  [Enter] diff  [b] branches  [c] checkout  [q] quit "
        stdscr.addstr(height-1, 0, bottom[:width-1], curses.color_pair(COLOR_STATUSBAR))
        stdscr.refresh()
        key = stdscr.getch()
        if key in (ord('q'), ord('Q'), 27):
            break
        elif key == curses.KEY_UP and selected_commit > 0:
            selected_commit -= 1
            sel_line = commit_indices[selected_commit]
            if sel_line < scroll:
                scroll = sel_line
        elif key == curses.KEY_DOWN and selected_commit < len(commit_indices) - 1:
            selected_commit += 1
            sel_line = commit_indices[selected_commit]
            if sel_line >= scroll + text_height:
                scroll = sel_line - text_height + 1
        elif key in (curses.KEY_ENTER, 10, 13):
            if sel['fullhash']:
                want_full = draw_scrollable(stdscr, get_commit_diff(cwd, sel['fullhash']).splitlines(),
                    f" COMMIT {sel['hash']} — {sel['msg'][:50]} ", "[Enter] full diff  ")
                if want_full:
                    draw_scrollable(stdscr, get_commit_full_diff(cwd, sel['fullhash']).splitlines(),
                        f" FULL DIFF {sel['hash']} ")
        elif key == ord('b'):
            branches = get_git_branches(cwd)
            if branches:
                labels = [("* " if cur else "  ") + n for n, cur in branches] + ["Cancel"]
                idx = draw_menu(stdscr, " BRANCHES ", labels)
                if idx is not None and idx < len(branches):
                    bname = branches[idx][0]
                    for ci, e in enumerate(entries):
                        if e['hash'] and bname in e['refs'] and ci in commit_indices:
                            selected_commit = commit_indices.index(ci)
                            scroll = max(0, ci - text_height // 2)
                            break
        elif key == ord('c'):
            target = None
            if sel['refs']:
                for ref in sel['refs'].split(','):
                    ref = ref.strip()
                    if ref and 'HEAD' not in ref and 'origin/' not in ref:
                        target = ref
                        break
            if not target:
                target = sel['fullhash'][:7]
            confirm = draw_menu(stdscr, " CHECKOUT ", [f"Checkout {target}?", "Yes", "Cancel"])
            if confirm == 1:
                out = git_checkout(cwd, target)
                draw_menu(stdscr, " RESULT ", [out[:60] if out else "done!", "OK"])
        elif key == curses.KEY_PPAGE:
            selected_commit = max(0, selected_commit - 10)
            scroll = max(0, commit_indices[selected_commit] - text_height // 2)
        elif key == curses.KEY_NPAGE:
            selected_commit = min(len(commit_indices)-1, selected_commit + 10)
            sel_line = commit_indices[selected_commit]
            if sel_line >= scroll + text_height:
                scroll = sel_line - text_height + 1

